---
interface Props {
  title: string;
  description: string;
  href: string;
  theme: 'grafismo' | 'automatizacion' | 'desarrollo' | 'fratelli';
  label: string;
  image?: string;
  video?: string;
}

const { title, description, href, theme, label, image, video } = Astro.props;

const themeColors: Record<string, { gradient: string; accent: string; glow: string }> = {
  grafismo: {
    gradient: 'linear-gradient(135deg, #050510 0%, #0A1628 100%)',
    accent: '#00D4FF',
    glow: 'rgba(0, 212, 255, 0.15)',
  },
  automatizacion: {
    gradient: 'linear-gradient(135deg, #0D1117 0%, #161B22 100%)',
    accent: '#39D353',
    glow: 'rgba(57, 211, 83, 0.15)',
  },
  desarrollo: {
    gradient: 'linear-gradient(135deg, #F0EDE8 0%, #E8E4DF 100%)',
    accent: '#5B7B9A',
    glow: 'rgba(91, 123, 154, 0.1)',
  },
  fratelli: {
    gradient: 'linear-gradient(135deg, #171B17 0%, #293320 100%)',
    accent: '#FF6B4A',
    glow: 'rgba(255, 107, 74, 0.22)',
  },
};

const colors = themeColors[theme];
const isLight = theme === 'desarrollo';
---

<a
  href={href}
  class:list={['area-card', `area-card--${theme}`, { 'area-card--light': isLight }]}
  style={`
    --card-gradient: ${colors.gradient};
    --card-accent: ${colors.accent};
    --card-glow: ${colors.glow};
  `}
>
  {image && (
    <div class="area-card__media" aria-hidden="true">
      <img class="area-card__poster" src={image} alt="" loading="lazy" decoding="async" />
      {video && (
        <video class="area-card__video" muted playsinline loop preload="none" data-src={video}></video>
      )}
      <div class="area-card__scrim"></div>
    </div>
  )}
  <div class="area-card__content">
    <span class="area-card__label mono">{label}</span>
    <h3 class="area-card__title">{title}</h3>
    <p class="area-card__desc">{description}</p>
    <span class="area-card__cta mono">
      Explorar →
    </span>
  </div>
  <div class="area-card__glow"></div>
</a>

<style>
  .area-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
    padding: var(--space-l);
    background: var(--card-gradient);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .area-card--light {
    border-color: rgba(0, 0, 0, 0.06);
  }

  .area-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-accent);
  }

  /* Media layer (real work behind the copy) */
  .area-card__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .area-card__poster,
  .area-card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .area-card__poster {
    filter: grayscale(1);
    opacity: 0.35;
    transform: scale(1.02);
    transition: filter var(--duration-slow) var(--ease-out),
                opacity var(--duration-slow) var(--ease-out),
                transform 1.2s var(--ease-out);
  }

  .area-card:hover .area-card__poster {
    filter: grayscale(0);
    opacity: 0.9;
    transform: scale(1.06);
  }

  .area-card__video {
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .area-card__video.is-playing {
    opacity: 1;
  }

  .area-card__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(4, 4, 12, 0) 0%, rgba(4, 4, 12, 0.55) 55%, rgba(4, 4, 12, 0.92) 100%);
  }

  /* The light card (desarrollo) flips dark on hover instead of showing dim media */
  .area-card--light .area-card__media {
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
    background: #060606;
  }

  .area-card--light:hover .area-card__media {
    opacity: 1;
  }

  .area-card--light .area-card__poster {
    filter: grayscale(0);
    opacity: 0.9;
  }

  .area-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .area-card__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--card-accent);
  }

  .area-card__title {
    font-size: var(--step-2);
    font-weight: 700;
    color: #FAFAFA;
    line-height: 1.15;
  }

  .area-card--light .area-card__title {
    color: #1A1A2E;
    transition: color var(--duration-base) var(--ease-out);
  }

  .area-card--light:hover .area-card__title {
    color: #FAFAFA;
  }

  .area-card__desc {
    font-size: var(--step--1);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 38ch;
  }

  .area-card--light .area-card__desc {
    color: rgba(0, 0, 0, 0.55);
    transition: color var(--duration-base) var(--ease-out);
  }

  .area-card--light:hover .area-card__desc {
    color: rgba(255, 255, 255, 0.65);
  }

  .area-card__cta {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--card-accent);
    margin-top: var(--space-xs);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .area-card:hover .area-card__cta {
    transform: translateX(4px);
  }

  /* Glow effect on hover */
  .area-card__glow {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 100%;
    background: var(--card-glow);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out);
    pointer-events: none;
  }

  .area-card:hover .area-card__glow {
    opacity: 1;
  }
</style>

<script>
  function initAreaCardVideos() {
    // Hover-only surface: skip on touch devices and for reduced-motion users
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    document.querySelectorAll<HTMLAnchorElement>('.area-card').forEach((card) => {
      const video = card.querySelector<HTMLVideoElement>('.area-card__video');
      if (!video) return;

      card.addEventListener('mouseenter', () => {
        // Lazy src: the clip only downloads on first hover
        if (!video.src && video.dataset.src) video.src = video.dataset.src;
        video.play().then(() => video.classList.add('is-playing')).catch(() => {});
      });

      card.addEventListener('mouseleave', () => {
        video.pause();
        video.currentTime = 0;
        video.classList.remove('is-playing');
      });
    });
  }

  document.addEventListener('astro:page-load', initAreaCardVideos);
</script>
