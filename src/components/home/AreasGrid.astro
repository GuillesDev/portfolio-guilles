---
import SectionHeading from '../global/SectionHeading.astro';
import AreaCard from './AreaCard.astro';
---

<section class="areas section" id="areas">
  <div class="container">
    <SectionHeading
      index="02"
      label="Portfolio"
      title="Lo que hago"
      align="center"
    >
      Cuatro mundos distintos, una misma forma de pensar.
    </SectionHeading>

    <div class="areas__grid" data-animate="stagger">
      <AreaCard
        title="Grafismo en TV"
        description="Directo, rótulos, cabeceras. Lo que ves en pantalla cuando enciendes la tele."
        href="/grafismo"
        theme="grafismo"
        label="01 / Broadcast"
        image="/media/grafismo/sin-ia/eurocopa-poster.jpg"
        video="/media/grafismo/sin-ia/eurocopa.mp4"
      />
      <AreaCard
        title="Automatización"
        description="Si lo hago más de dos veces, lo automatizo. Plantillas, scripts y sistemas que trabajan solos."
        href="/automatizacion"
        theme="automatizacion"
        label="02 / Sistemas"
        image="/media/automatizacion/cartelas-si-poster.jpg"
        video="/media/automatizacion/cartelas-si-holo.mp4"
      />
      <AreaCard
        title="Desarrollo Web"
        description="Webs que funcionan, no solo que quedan bonitas. Diseño, código y producto real."
        href="/desarrollo"
        theme="desarrollo"
        label="03 / Digital"
        image="/media/blackgum/cinematic-reveal-poster.jpg"
        video="/media/blackgum/cinematic-reveal.mp4"
      />
      <AreaCard
        title="Fratelli Pazzi"
        description="Una pizzería real. Marca, carta, cartelería, redes y piezas para el local diseñadas desde cero."
        href="/fratelli-pazzi"
        theme="fratelli"
        label="04 / Negocio"
        image="/media/fratelli/videos/timelapse-pizza-v2-poster.jpg"
        video="/media/fratelli/videos/timelapse-pizza-v2.web.mp4"
      />
    </div>
  </div>
</section>

<style>
  .areas__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-m);
  }

  @media (max-width: 768px) {
    .areas__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
