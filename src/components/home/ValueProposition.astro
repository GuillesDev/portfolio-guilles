---
import SectionHeading from '../global/SectionHeading.astro';
---

<section class="value section" id="propuesta">
  <div class="container">
    <SectionHeading index="01" label="Propuesta de valor" title="¿Por qué yo?" />

    <div class="value__text" data-animate="fade-up">
      <p class="value__lead">
        No encajo en una sola casilla. Y eso es lo bueno.
      </p>
      <p>
        Sé lo que es trabajar para emisión en directo, con tiempos reales y sin margen para fallar.
        También sé lo que es montar un negocio desde cero, diseñar su marca,
        programar su web y pelearse con los proveedores. Cada cosa que hago
        alimenta a las demás, y eso se nota en el resultado.
      </p>
    </div>

    <div class="value__stats" data-animate="fade-up">
      <div class="value__stat">
        <span class="value__number"><span data-counter="5">5</span><span class="value__number-accent">+</span></span>
        <span class="value__label mono">Años en TV</span>
      </div>
      <div class="value__stat">
        <span class="value__number" data-counter="3">3</span>
        <span class="value__label mono">Cadenas nacionales</span>
      </div>
      <div class="value__stat">
        <span class="value__number" data-counter="4">4</span>
        <span class="value__label mono">Disciplinas</span>
      </div>
      <div class="value__stat">
        <span class="value__number" data-counter="1">1</span>
        <span class="value__label mono">Negocio propio</span>
      </div>
    </div>
  </div>
</section>

<style>
  .value__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-m);
  }

  .value__lead {
    font-size: var(--step-1);
    line-height: 1.45;
    color: var(--color-primary);
    font-weight: 500;
    max-width: 60ch;
  }

  .value__text p:not(.value__lead) {
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 60ch;
  }

  .value__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: var(--space-2xl);
  }

  .value__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-2xs);
    padding: var(--space-s) var(--space-xs);
  }

  .value__stat + .value__stat {
    border-left: 1px solid var(--color-border);
  }

  .value__number {
    font-family: 'Syne Variable', 'Syne', sans-serif;
    font-size: var(--step-4);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .value__number-accent {
    color: var(--color-accent);
  }

  .value__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .value__stats {
      grid-template-columns: 1fr 1fr;
      margin-top: var(--space-xl);
    }

    .value__stat {
      padding: var(--space-m) var(--space-xs);
    }

    /* 2x2: hairline only between the two columns and between the two rows */
    .value__stat + .value__stat {
      border-left: 0;
    }

    .value__stat:nth-child(even) {
      border-left: 1px solid var(--color-border);
    }

    .value__stat:nth-child(n + 3) {
      border-top: 1px solid var(--color-border);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initStatCounters() {
    const counters = document.querySelectorAll<HTMLElement>('[data-counter]');
    if (!counters.length) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    counters.forEach((el) => {
      const target = parseInt(el.dataset.counter || '0', 10);
      if (reduced || !Number.isFinite(target)) {
        el.textContent = String(target);
        return;
      }

      const state = { value: 0 };
      el.textContent = '0';
      gsap.to(state, {
        value: target,
        duration: 1.4,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          once: true,
        },
        onUpdate: () => {
          el.textContent = String(Math.round(state.value));
        },
      });
    });
  }

  document.addEventListener('astro:page-load', initStatCounters);
</script>
