---
import Button from '../global/Button.astro';
---

<section class="hero">
  <div class="hero__bg">
    <video
      class="hero__reel"
      id="hero-reel"
      muted
      playsinline
      preload="metadata"
    ></video>
    <div class="hero__reel-overlay"></div>
    <div class="hero__gradient"></div>
    <div class="hero__grid"></div>
  </div>

  <div class="hero__content container">
    <h1 class="hero__title" id="hero-title">
      <span class="hero__line"><span class="hero__line-inner">Guillermo</span></span>
      <span class="hero__line"><span class="hero__line-inner hero__title-accent">López</span></span>
    </h1>

    <p class="hero__role mono" data-animate="fade-up">
      <span class="hero__role-fixed">Soy</span>
      <span class="hero__role-roll" aria-hidden="false">
        <span class="hero__role-list" id="hero-role-list">
          <span class="hero__role-item">grafista de TV</span>
          <span class="hero__role-item">motion designer</span>
          <span class="hero__role-item">desarrollador</span>
          <span class="hero__role-item">fundador</span>
          <span class="hero__role-item" aria-hidden="true">grafista de TV</span>
        </span>
      </span>
    </p>

    <p class="hero__subtitle" data-animate="fade-up">
      Hago que las cosas se vean bien, funcionen solas y tengan sentido.
    </p>

    <div class="hero__actions" data-animate="fade-up">
      <Button href="#areas" variant="primary" size="lg">Ver portfolio</Button>
      <Button href="/cv/guillermo-lopez-cv.pdf" variant="secondary" size="lg" download>
        Descargar CV ↓
      </Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* Background effects */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__reel {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1.5s ease;
  }

  .hero__reel.is-playing {
    opacity: 0.2;
  }

  .hero__reel-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 80% 70% at 50% 50%,
      transparent 0%,
      var(--color-bg) 75%
    );
    z-index: 1;
  }

  .hero__gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 50% at 50% -10%, rgba(59, 130, 246, 0.18) 0%, transparent 60%),
      radial-gradient(ellipse 50% 50% at 20% 60%, rgba(59, 130, 246, 0.07) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(59, 130, 246, 0.10) 0%, transparent 50%);
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black, transparent);
  }

  /* Content */
  .hero__content {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--space-3xl) + 80px);
    padding-bottom: var(--space-3xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__title {
    font-size: clamp(3rem, 11.3vw, 10.25rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.05em;
    color: var(--color-primary);
    margin-bottom: var(--space-m);
    max-width: 100%;
  }

  .hero__line {
    display: block;
    overflow: hidden;
    /* Breathing room so descenders and the accent gradient don't get clipped */
    padding-bottom: 0.06em;
    margin-bottom: -0.06em;
  }

  .hero__line-inner {
    display: inline-block;
    transform: translateY(112%);
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__line-inner {
      transform: none;
    }
  }

  .hero__title-accent {
    background: linear-gradient(135deg, #FAFAFA 20%, var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__role {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6em;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-m);
  }

  .hero__role-roll {
    display: inline-block;
    overflow: hidden;
    height: 1.4em;
    line-height: 1.4;
    vertical-align: bottom;
  }

  .hero__role-list {
    display: flex;
    flex-direction: column;
    transition: transform 0.6s var(--ease-out);
  }

  .hero__role-item {
    display: block;
    height: 1.4em;
    line-height: 1.4;
    color: var(--color-primary);
    text-align: left;
    white-space: nowrap;
  }

  .hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 52ch;
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .hero__actions {
    display: flex;
    justify-content: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero__content {
      padding-top: calc(var(--space-2xl) + 60px);
    }

    .hero__title {
      font-size: clamp(2.4rem, 14vw, 4.5rem);
      line-height: 0.95;
      letter-spacing: -0.04em;
    }

    .hero__role {
      font-size: var(--step--2);
    }

    .hero__subtitle {
      max-width: 30ch;
      padding-inline: var(--space-2xs);
    }

    .hero__actions {
      flex-direction: column;
    }

    .hero__reel.is-playing {
      opacity: 0.14;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  let roleTimer: ReturnType<typeof setInterval> | null = null;

  function initHeroIntro() {
    const title = document.getElementById('hero-title');
    const roleList = document.getElementById('hero-role-list');
    if (roleTimer) {
      clearInterval(roleTimer);
      roleTimer = null;
    }
    if (!title) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const lines = title.querySelectorAll('.hero__line-inner');

    if (reduced) {
      gsap.set(lines, { clearProps: 'transform' });
      return;
    }

    // The CSS sets translateY(112%) as the pre-JS hidden state; GSAP parses that
    // into a px-based `y`, so reset it explicitly and animate yPercent instead.
    gsap.fromTo(
      lines,
      { y: 0, yPercent: 112 },
      { yPercent: 0, duration: 1.1, ease: 'power4.out', stagger: 0.12, delay: 0.15 }
    );

    if (!roleList) return;
    const items = roleList.children.length; // last one is a clone of the first
    let index = 0;
    roleList.style.transform = 'translateY(0)';

    roleTimer = setInterval(() => {
      index += 1;
      roleList.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
      roleList.style.transform = `translateY(-${index * 1.4}em)`;

      if (index === items - 1) {
        // Landed on the clone: snap back to the real first item without transition
        setTimeout(() => {
          roleList.style.transition = 'none';
          roleList.style.transform = 'translateY(0)';
          index = 0;
        }, 650);
      }
    }, 2600);
  }

  document.addEventListener('astro:page-load', initHeroIntro);
  document.addEventListener('astro:before-swap', () => {
    if (roleTimer) {
      clearInterval(roleTimer);
      roleTimer = null;
    }
  });

  function initHeroReel() {
    // Respect reduced-motion: keep the static gradient background, skip the video reel
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const video = document.getElementById('hero-reel') as HTMLVideoElement | null;
    if (!video) return;
    const heroVideo: HTMLVideoElement = video;

    const videos = [
      '/media/grafismo/ia/che-iglesias.mp4',
      '/media/grafismo/ia/abascal-wars.mp4',
      '/media/grafismo/ia/aforama.mp4',
      '/media/grafismo/ia/begona-desafiante.mp4',
      '/media/grafismo/ia/hulk-sanchez.mp4',
      '/media/grafismo/ia/los-panceta.mp4',
      '/media/grafismo/ia/paganos.mp4',
      '/media/grafismo/ia/personas-bestias.mp4',
      '/media/grafismo/ia/sanchez-barco.mp4',
      '/media/grafismo/ia/sanchez-esqui.mp4',
      '/media/grafismo/ia/sanchez-lightyear.mp4',
      '/media/grafismo/ia/trileros-sanchez-trump.mp4',
      '/media/grafismo/ia/vox-is-coming.mp4',
      '/media/grafismo/ia/yolanda-oscars.mp4',
    ];

    let index = Math.floor(Math.random() * videos.length);

    function playNext() {
      // Fade out
      heroVideo.classList.remove('is-playing');

      setTimeout(() => {
        heroVideo.src = videos[index];
        index = (index + 1) % videos.length;

        heroVideo.load();
        heroVideo.play().then(() => {
          heroVideo.classList.add('is-playing');
        }).catch(() => {});
      }, 1500); // wait for fade-out
    }

    heroVideo.addEventListener('ended', playNext);

    // Start first video
    heroVideo.src = videos[index];
    index = (index + 1) % videos.length;
    heroVideo.load();
    heroVideo.play().then(() => {
      heroVideo.classList.add('is-playing');
    }).catch(() => {});
  }

  document.addEventListener('astro:page-load', initHeroReel);
</script>
