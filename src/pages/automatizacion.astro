---
import SectionLayout from '../layouts/SectionLayout.astro';
import { automatizacionVisualisers } from '../data/projects';
---

<SectionLayout
  title="Automatización — Guillermo López"
  description="Detecto procesos repetitivos y los convierto en sistemas automáticos. Plantillas, expresiones y scripts que multiplican la eficiencia."
  theme="automatizacion"
>
  <!-- Number particles background -->
  <canvas class="auto-particles" id="auto-particles" aria-hidden="true"></canvas>

  <!-- Hero título -->
  <section class="auto-hero">
    <div class="auto-hero__content container">
      <h1 class="auto-hero__title">
        <span class="auto-hero__title--full">Automatización</span>
        <span class="auto-hero__title--short">Automatizar</span>
      </h1>
      <p class="auto-hero__sub">Detecto lo repetitivo, lo convierto en sistema y me olvido.</p>
      <div class="auto-hero__tracks mono">
        <a class="auto-hero__track" href="#after-effects"><span>01</span> After Effects</a>
        <a class="auto-hero__track" href="#empresas"><span>02</span> Soluciones para empresas</a>
      </div>
    </div>
  </section>

  <!-- ━━ Bloque 01 · After Effects ━━ -->
  <div class="track" id="after-effects">
    <div class="container track__inner" data-animate="fade-up">
      <span class="track__num" aria-hidden="true">01</span>
      <div class="track__text">
        <span class="track__kicker mono">// after effects</span>
        <h2 class="track__title">Grafismo que se monta solo</h2>
        <p class="track__sub">Plantillas, expresiones y scripts que convierten horas de rotulación en un click.</p>
      </div>
    </div>
  </div>

  <!-- Showcase — lo primero que se ve -->
  <section class="showcase" aria-label="Plantillas automatizadas">
    <div class="showcase__viewport">
      {automatizacionVisualisers.map((item, index) => (
        <article
          class={`showcase__slide ${index === 0 ? 'is-active' : ''}`}
          data-index={index}
        >
          <video
            class="showcase__video"
            preload="metadata"
            playsinline
            muted
            loop
            poster={item.poster}
          >
            <source src={item.video} type="video/mp4" />
          </video>
        </article>
      ))}
    </div>

    <button class="showcase__nav showcase__nav--prev" aria-label="Anterior" data-dir="-1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="showcase__nav showcase__nav--next" aria-label="Siguiente" data-dir="1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div class="showcase__dots">
      {automatizacionVisualisers.map((_, i) => (
        <button
          class={`showcase__dot ${i === 0 ? 'is-active' : ''}`}
          data-goto={i}
          aria-label={`Ir a plantilla ${i + 1}`}
        >
          <span class="showcase__dot-fill"></span>
        </button>
      ))}
    </div>
  </section>

  <!-- Terminal accent -->
  <section class="terminal-strip">
    <div class="container">
      <div class="terminal-strip__block mono">
        <span><span class="terminal-prompt">~</span> <span class="terminal-cmd">find</span> <span class="terminal-arg">./trabajo</span> <span class="terminal-flag">--repetitivo</span></span>
        <span class="terminal-output">→ 47 procesos manuales</span>
        <span><span class="terminal-prompt">~</span> <span class="terminal-cmd">automatizar</span> <span class="terminal-flag">--todos</span></span>
        <span class="terminal-success">✓ Hecho.</span>
      </div>
    </div>
  </section>

  <!-- Pipeline: problema → sistema → resultado -->
  <section class="pipeline section">
    <div class="container">
      <div class="pipeline__header" data-animate="fade-up">
        <h2 class="pipeline__title">Cómo funciona mi cabeza</h2>
        <p class="pipeline__desc">
          Cada vez que hago algo más de una vez, pienso:
          <em>"esto se puede automatizar"</em>. Y lo hago.
        </p>
      </div>

      <div class="pipeline__flow" data-animate="stagger">
        <div class="pipeline__node pipeline__node--problem">
          <div class="pipeline__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M8 15h8"/><circle cx="9" cy="9" r="1" fill="currentColor"/><circle cx="15" cy="9" r="1" fill="currentColor"/>
            </svg>
          </div>
          <h3 class="pipeline__node-title">El problema</h3>
          <p class="pipeline__node-text">"Llevo 2 horas cambiando rótulos a mano y aún me quedan 40"</p>
        </div>

        <div class="pipeline__connector" aria-hidden="true">
          <svg viewBox="0 0 80 24" fill="none">
            <path d="M0 12h60" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/>
            <path d="M56 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2" fill="none"/>
          </svg>
        </div>

        <div class="pipeline__node pipeline__node--system">
          <div class="pipeline__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h3 class="pipeline__node-title">El sistema</h3>
          <p class="pipeline__node-text">Plantilla + expresiones + variables = un click y listo</p>
        </div>

        <div class="pipeline__connector" aria-hidden="true">
          <svg viewBox="0 0 80 24" fill="none">
            <path d="M0 12h60" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/>
            <path d="M56 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2" fill="none"/>
          </svg>
        </div>

        <div class="pipeline__node pipeline__node--result">
          <div class="pipeline__icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <h3 class="pipeline__node-title">El resultado</h3>
          <p class="pipeline__node-text">40 rótulos en 2 minutos. Y te sobra tiempo para el café.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Antes → Después -->
  <section class="examples section">
    <div class="container">
      <div class="examples__header" data-animate="fade-up">
        <h2 class="examples__title">Antes → Después</h2>
        <p class="examples__desc">Ejemplos reales de lo que automatizo en el día a día.</p>
      </div>

      <div class="examples__grid" data-animate="stagger">
        <div class="example-card">
          <div class="example-card__before">
            <span class="example-card__label mono">Antes</span>
            <p>Cambiar texto, color y datos en 47 rótulos uno a uno</p>
          </div>
          <div class="example-card__arrow" aria-hidden="true">→</div>
          <div class="example-card__after">
            <span class="example-card__label example-card__label--after mono">Después</span>
            <p>Un JSON con los datos y el sistema lo hace solo</p>
          </div>
        </div>

        <div class="example-card">
          <div class="example-card__before">
            <span class="example-card__label mono">Antes</span>
            <p>Ajustar colores de marca en cada pieza manualmente</p>
          </div>
          <div class="example-card__arrow" aria-hidden="true">→</div>
          <div class="example-card__after">
            <span class="example-card__label example-card__label--after mono">Después</span>
            <p>Cambio una variable y todo se actualiza al instante</p>
          </div>
        </div>

        <div class="example-card">
          <div class="example-card__before">
            <span class="example-card__label mono">Antes</span>
            <p>Exportar 20 versiones con distintos textos y formatos</p>
          </div>
          <div class="example-card__arrow" aria-hidden="true">→</div>
          <div class="example-card__after">
            <span class="example-card__label example-card__label--after mono">Después</span>
            <p>Un script renderiza todo mientras me tomo el café</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ━━ Bloque 02 · Soluciones para empresas ━━ -->
  <div class="track" id="empresas">
    <div class="container track__inner" data-animate="fade-up">
      <span class="track__num" aria-hidden="true">02</span>
      <div class="track__text">
        <span class="track__kicker mono">// soluciones para empresas</span>
        <h2 class="track__title">Bots que trabajan por tu empresa</h2>
        <p class="track__sub">
          No solo automatizo gráficos: monto <strong>chatbots y asistentes</strong> que atienden,
          agendan citas y captan clientes mientras tú haces otra cosa. La demo de abajo se está
          ejecutando sola, igual que lo haría en tu web o tu WhatsApp.
        </p>
      </div>
    </div>
  </div>

  <!-- Bots para empresas -->
  <section class="bots section">
    <div class="container">
      <div class="bots__demo" data-animate="fade-up">
        <!-- Demo: chatbot conversando solo -->
        <div class="chat-demo">
          <div class="chat-demo__bar mono">
            <span class="chat-demo__status" aria-hidden="true"></span>
            <span class="chat-demo__name">asistente — Clínica Dental Sonrisa</span>
            <span class="chat-demo__tag">demo</span>
          </div>
          <div class="chat-demo__messages" id="chat-messages" aria-label="Conversación de ejemplo con un chatbot de empresa"></div>
          <div class="chat-demo__input mono" aria-hidden="true">
            <span>Escribe un mensaje…</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
        </div>

        <!-- Cómo lo monto: diagrama + pasos -->
        <div class="bots__how">
          <h3 class="bots__how-title mono">// cómo lo monto</h3>

          <div class="bots__flow" aria-hidden="true">
            <div class="bots__flow-node">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              <span>Web · WhatsApp<br />· Instagram</span>
            </div>
            <div class="bots__flow-arrow">
              <svg viewBox="0 0 60 24" fill="none"><path class="bots__dash" d="M0 12h44" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/><path d="M40 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2"/></svg>
            </div>
            <div class="bots__flow-node bots__flow-node--bot">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="7" width="14" height="12" rx="3"/><line x1="12" y1="7" x2="12" y2="3"/><circle cx="12" cy="3" r="1" fill="currentColor"/><circle cx="9.5" cy="12.5" r="1" fill="currentColor"/><circle cx="14.5" cy="12.5" r="1" fill="currentColor"/><path d="M9 16h6"/></svg>
              <span>Bot<br />reglas + IA</span>
            </div>
            <div class="bots__flow-arrow">
              <svg viewBox="0 0 60 24" fill="none"><path class="bots__dash" d="M0 12h44" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/><path d="M40 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2"/></svg>
            </div>
            <div class="bots__flow-node">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Agenda · CRM<br />· Email</span>
            </div>
          </div>

          <ol class="bots__steps">
            <li><strong>Escucho.</strong> ¿Dónde pierde tiempo tu equipo? Preguntas repetidas, citas, presupuestos…</li>
            <li><strong>Diseño el flujo.</strong> Árbol de conversación + IA para lo que se salga del guion.</li>
            <li><strong>Lo conecto a tus herramientas.</strong> Agenda, CRM, email o WhatsApp: el bot ejecuta, no solo habla.</li>
            <li><strong>Mido y mejoro.</strong> Cada conversación queda registrada: se ve qué pregunta la gente y qué convierte.</li>
          </ol>
        </div>
      </div>

      <div class="bots__uses" data-animate="stagger">
        <div class="bot-use">
          <div class="bot-use__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="bot-use__title">Atención 24/7</h3>
          <p class="bot-use__text">Responde al instante las preguntas de siempre: horarios, precios, ubicación. Sin esperas y sin interrumpir a nadie del equipo.</p>
        </div>
        <div class="bot-use">
          <div class="bot-use__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M9 16l2 2 4-4"/></svg>
          </div>
          <h3 class="bot-use__title">Reservas y citas</h3>
          <p class="bot-use__text">El bot mira la agenda, propone hueco, reserva y manda recordatorios. Menos llamadas y menos citas perdidas.</p>
        </div>
        <div class="bot-use">
          <div class="bot-use__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-6l-2 3h-4l-2-3H2"/><path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/></svg>
          </div>
          <h3 class="bot-use__title">Captación de leads</h3>
          <p class="bot-use__text">Hace las preguntas clave, cualifica al cliente y te lo deja en el CRM o en el email con todo el contexto. Tú solo cierras.</p>
        </div>
      </div>
    </div>
  </section>

</SectionLayout>

<script is:inline>
  // ── Chat demo: la conversación se escribe sola en bucle ──
  (() => {
    const SCRIPT = [
      { from: 'user', text: 'Hola, ¿hacéis blanqueamiento dental?' },
      { from: 'bot', text: '¡Claro! 😁 El blanqueamiento LED son 150 €. ¿Quieres una valoración gratuita antes?' },
      { from: 'user', text: 'Sí, ¿tenéis hueco el jueves por la tarde?' },
      { from: 'bot', text: 'Déjame mirar la agenda… ✅ Jueves 17:30 con la Dra. Ruiz. ¿Te lo reservo?' },
      { from: 'user', text: 'Perfecto, resérvalo' },
      { from: 'bot', text: 'Hecho 📅 Te llega la confirmación por WhatsApp y un recordatorio el día antes.' },
      { from: 'sys', text: '→ cita creada en la agenda · lead guardado en el CRM · aviso enviado a la clínica' },
    ];

    function addMsg(box, from, text) {
      const el = document.createElement('div');
      el.className = 'chat-msg chat-msg--' + from;
      el.textContent = text;
      box.appendChild(el);
      box.scrollTop = box.scrollHeight;
      return el;
    }

    function initChatDemo() {
      const box = document.getElementById('chat-messages');
      if (!box || box.dataset.init) return;
      box.dataset.init = '1';

      // Reduced motion: render the whole conversation statically, no loop
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        SCRIPT.forEach((m) => addMsg(box, m.from, m.text));
        return;
      }

      let i = 0;
      let timer = 0;

      function step() {
        if (!box.isConnected) return; // page swapped away — stop
        if (i >= SCRIPT.length) {
          // Conversation over: pause, clear, restart
          timer = setTimeout(() => {
            box.innerHTML = '';
            i = 0;
            step();
          }, 4200);
          return;
        }
        const msg = SCRIPT[i++];
        if (msg.from === 'bot') {
          const typing = addMsg(box, 'bot chat-msg--typing', '');
          typing.innerHTML = '<i></i><i></i><i></i>';
          timer = setTimeout(() => {
            typing.remove();
            addMsg(box, msg.from, msg.text);
            timer = setTimeout(step, 1400);
          }, 1100);
        } else {
          addMsg(box, msg.from, msg.text);
          timer = setTimeout(step, msg.from === 'sys' ? 1600 : 1000);
        }
      }

      // Start when the demo scrolls into view
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          step();
        }
      }, { threshold: 0.35 });
      io.observe(box);
    }

    initChatDemo();
    document.addEventListener('astro:page-load', initChatDemo);
  })();

  // ── Showcase slider ──
  (() => {
    const slides = document.querySelectorAll('.showcase__slide');
    const dots   = document.querySelectorAll('.showcase__dot');
    const navs   = document.querySelectorAll('.showcase__nav');
    let current  = 0;
    let transitioning = false;

    function goTo(index) {
      if (transitioning || index === current) return;
      transitioning = true;
      const prev = slides[current];
      const next = slides[index];
      const prevVideo = prev.querySelector('video');
      if (prevVideo) { prevVideo.pause(); prevVideo.currentTime = 0; }
      next.classList.add('is-entering');
      requestAnimationFrame(() => {
        next.classList.add('is-active');
        next.classList.remove('is-entering');
        prev.classList.remove('is-active');
        const nextVideo = next.querySelector('video');
        if (nextVideo) nextVideo.play().catch(() => {});
        dots[current].classList.remove('is-active');
        dots[index].classList.add('is-active');
        current = index;
        setTimeout(() => { transitioning = false; }, 600);
      });
    }

    navs.forEach(btn => {
      btn.addEventListener('click', () => {
        const dir = parseInt(btn.dataset.dir);
        goTo((current + dir + slides.length) % slides.length);
      });
    });

    dots.forEach(dot => {
      dot.addEventListener('click', () => goTo(parseInt(dot.dataset.goto)));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goTo((current + 1) % slides.length);
      if (e.key === 'ArrowLeft')  goTo((current - 1 + slides.length) % slides.length);
    });

    const firstVideo = slides[0]?.querySelector('video');
    if (firstVideo) firstVideo.play().catch(() => {});
  })();

  // ── Number particles ──
  (() => {
    // Respect reduced-motion: skip the continuous particle animation entirely
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = document.getElementById('auto-particles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, particles = [];
    let mouse = { x: -9999, y: -9999 };
    let raf;

    // Meaningful tokens: automation metrics, binary, code fragments
    const tokens = [
      '0', '1', '0', '1', '0', '1',
      '47', '02', '40', '×10',
      '{}', '()', '=>', '//',
      '0:02', '%', '++', '--',
      'for', 'if', '0x', '&&',
      '47→2', '···', '█', '▓',
    ];

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function createParticle() {
      const size = 10 + Math.random() * 14;
      return {
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: -0.15 - Math.random() * 0.25,
        text: tokens[Math.floor(Math.random() * tokens.length)],
        size: size,
        alpha: 0.04 + Math.random() * 0.08,
        baseAlpha: 0.04 + Math.random() * 0.08,
        phase: Math.random() * Math.PI * 2,
        phaseSpeed: 0.005 + Math.random() * 0.01,
      };
    }

    function init() {
      resize();
      particles = [];
      const count = Math.min(80, Math.floor((w * h) / 18000));
      for (let i = 0; i < count; i++) {
        particles.push(createParticle());
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      const mouseRadius = 120;

      for (const p of particles) {
        p.phase += p.phaseSpeed;
        p.x += p.vx;
        p.y += p.vy;

        // Wrap
        if (p.y < -30) { p.y = h + 30; p.x = Math.random() * w; }
        if (p.x < -30) p.x = w + 30;
        if (p.x > w + 30) p.x = -30;

        // Mouse repulsion
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouseRadius) {
          const force = (1 - dist / mouseRadius) * 0.6;
          p.x += (dx / dist) * force * 2;
          p.y += (dy / dist) * force * 2;
        }

        // Pulse
        const pulse = 0.6 + 0.4 * Math.sin(p.phase);
        const alpha = p.baseAlpha * pulse;

        ctx.font = `600 ${p.size}px "JetBrains Mono", monospace`;
        ctx.fillStyle = `rgba(57, 211, 83, ${alpha})`;
        ctx.fillText(p.text, p.x, p.y);
      }

      raf = requestAnimationFrame(draw);
    }

    window.addEventListener('resize', () => { resize(); });
    document.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    document.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

    init();
    draw();

    // Cleanup on page transition
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
    });
  })();
</script>

<style>
  /* ── Number particles ── */
  .auto-particles {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  /* ── Hero título ── */
  .auto-hero {
    position: relative;
    z-index: 1;
    background: transparent;
    padding-top: calc(var(--space-2xl) + 80px);
    padding-bottom: var(--space-xl);
  }

  .auto-hero__content {
    text-align: center;
  }

  .auto-hero__title {
    font-size: clamp(3rem, 2rem + 5vw, 6rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, #39D353 0%, #39D353 40%, #a8f0b0 65%, #ffffff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-s);
    max-width: 100%;
    white-space: nowrap;
  }

  .auto-hero__title--full {
    display: inline;
  }

  .auto-hero__title--short {
    display: none;
  }

  .auto-hero__sub {
    font-size: var(--step-0);
    color: var(--auto-text-secondary);
    line-height: 1.5;
    max-width: 45ch;
    margin-inline: auto;
  }

  /* ── Terminal strip ── */
  .terminal-strip {
    background: var(--auto-bg);
    padding-block: var(--space-m);
  }

  .terminal-strip__block {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-m);
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.65rem, 0.45rem + 0.6vw, 0.78rem);
    color: var(--auto-text-secondary);
    opacity: 0.6;
  }

  .terminal-prompt {
    color: var(--auto-accent);
  }

  .terminal-cmd {
    color: var(--auto-primary);
    font-weight: 600;
  }

  .terminal-arg {
    color: var(--auto-text-secondary);
  }

  .terminal-flag {
    color: #79C0FF;
  }

  .terminal-output {
    color: var(--auto-text-secondary);
  }

  .terminal-success {
    color: var(--auto-accent);
  }

  /* ── Showcase ── */
  .showcase {
    position: relative;
    width: 100%;
    height: 80vh;
    height: 80dvh;
    --showcase-side-trim: clamp(20px, 5vw, 86px);
    background:
      radial-gradient(ellipse 90% 80% at 50% 50%, rgba(57, 211, 83, 0.08) 0%, transparent 72%),
      linear-gradient(180deg, #0D1117 0%, #121821 100%);
    overflow: hidden;
  }

  .showcase::before,
  .showcase::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: max(7vw, 56px);
    z-index: 2;
    pointer-events: none;
  }

  .showcase::before {
    left: 0;
    background: linear-gradient(to right, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.35) 100%);
  }

  .showcase::after {
    right: 0;
    background: linear-gradient(to left, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.35) 100%);
  }

  .showcase__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .showcase__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    z-index: 0;
  }

  .showcase__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .showcase__slide.is-entering {
    visibility: visible;
  }

  .showcase__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    clip-path: inset(0 var(--showcase-side-trim));
  }

  .showcase__overlay {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  .showcase__counter {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
  }

  .showcase__title {
    font-size: clamp(1.6rem, 1rem + 2.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .showcase__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-top: var(--space-3xs);
  }

  .showcase__tag {
    font-size: var(--step--2);
    padding: 0.2em 0.6em;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.75);
  }

  .showcase__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 62px;
    height: 62px;
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, rgba(121, 192, 255, 0.22) 0%, rgba(57, 211, 83, 0.24) 100%);
    backdrop-filter: blur(10px) saturate(1.2);
    -webkit-backdrop-filter: blur(10px) saturate(1.2);
    border: 1px solid rgba(57, 211, 83, 0.45);
    border-radius: 50%;
    color: #E6EDF3;
    cursor: pointer;
    box-shadow: 0 0 0 1px rgba(121, 192, 255, 0.2), 0 0 28px rgba(57, 211, 83, 0.28);
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .showcase__nav svg {
    width: 28px;
    height: 28px;
    filter: drop-shadow(0 0 8px rgba(57, 211, 83, 0.45));
  }

  .showcase__nav:hover {
    background: linear-gradient(145deg, rgba(121, 192, 255, 0.34) 0%, rgba(57, 211, 83, 0.38) 100%);
    border-color: rgba(57, 211, 83, 0.78);
    box-shadow: 0 0 0 1px rgba(121, 192, 255, 0.4), 0 0 40px rgba(57, 211, 83, 0.45);
    transform: translateY(-50%) scale(1.1);
  }

  .showcase__nav--prev { left: var(--space-m); }
  .showcase__nav--next { right: var(--space-m); }

  .showcase__dots {
    position: absolute;
    bottom: var(--space-m);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: var(--space-xs);
  }

  .showcase__dot {
    width: 36px;
    height: 4px;
    padding: 0;
    border: none;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
    position: relative;
    transition: background 0.3s ease;
  }

  .showcase__dot.is-active {
    background: rgba(255, 255, 255, 0.5);
  }

  .showcase__dot-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: #fff;
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .showcase__dot.is-active .showcase__dot-fill {
    transform: scaleX(1);
  }

  /* ── Pipeline ── */
  .pipeline__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .pipeline__title {
    font-size: var(--step-3);
    color: var(--auto-primary);
    margin-bottom: var(--space-s);
  }

  .pipeline__desc {
    color: var(--auto-text-secondary);
    font-size: var(--step-0);
    line-height: 1.6;
    max-width: 50ch;
    margin-inline: auto;
  }

  .pipeline__desc em {
    color: var(--auto-accent);
    font-style: normal;
    font-weight: 600;
  }

  .pipeline__flow {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .pipeline__node {
    flex: 1;
    padding: var(--space-l);
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xs);
    transition: border-color 0.25s ease;
  }

  .pipeline__node:hover {
    border-color: var(--auto-accent);
  }

  .pipeline__node--problem .pipeline__icon { color: #F85149; }
  .pipeline__node--system .pipeline__icon  { color: #79C0FF; }
  .pipeline__node--result .pipeline__icon  { color: var(--auto-accent); }

  .pipeline__icon {
    margin-bottom: var(--space-3xs);
  }

  .pipeline__node-title {
    font-size: var(--step-0);
    font-weight: 700;
    color: var(--auto-primary);
  }

  .pipeline__node-text {
    font-size: var(--step--1);
    color: var(--auto-text-secondary);
    line-height: 1.6;
  }

  .pipeline__connector {
    flex-shrink: 0;
    width: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pipeline__connector svg {
    width: 100%;
    height: 24px;
  }

  /* ── Examples before/after ── */
  .examples__header {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .examples__title {
    font-size: var(--step-3);
    color: var(--auto-primary);
    margin-bottom: var(--space-s);
  }

  .examples__desc {
    color: var(--auto-text-secondary);
    font-size: var(--step-0);
    line-height: 1.6;
    text-align: center;
    margin-inline: auto;
  }

  .examples__grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .example-card {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.25s ease;
  }

  .example-card:hover {
    border-color: var(--auto-accent);
  }

  .example-card__before,
  .example-card__after {
    flex: 1;
    padding: var(--space-m) var(--space-l);
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .example-card__before {
    background: rgba(248, 81, 73, 0.04);
  }

  .example-card__after {
    background: rgba(57, 211, 83, 0.04);
  }

  .example-card__before p {
    color: var(--auto-text-secondary);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .example-card__after p {
    color: var(--auto-primary);
    font-size: var(--step--1);
    line-height: 1.5;
    font-weight: 500;
  }

  .example-card__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #F85149;
  }

  .example-card__label--after {
    color: var(--auto-accent);
  }

  .example-card__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--space-s);
    font-size: var(--step-1);
    color: var(--auto-accent);
    font-weight: 700;
    flex-shrink: 0;
    background: var(--auto-surface);
  }

  /* ── Section spacing ── */
  .section {
    padding-block: var(--space-3xl);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .auto-hero {
      overflow-x: clip;
    }

    .auto-hero__title--short {
      display: inline;
    }

    .auto-hero__title--full {
      display: none;
    }

    .auto-hero__title {
      font-size: clamp(1.6rem, 0.8rem + 5vw, 2.4rem);
      line-height: 1.02;
      letter-spacing: -0.03em;
    }

    .auto-hero__sub {
      max-width: 30ch;
      padding-inline: var(--space-2xs);
    }

    .showcase {
      height: 65vh;
      height: 65dvh;
      --showcase-side-trim: 8px;
      overflow-x: clip;
    }

    .showcase__nav {
      width: 50px;
      height: 50px;
    }

    .showcase__nav--prev { left: var(--space-xs); }
    .showcase__nav--next { right: var(--space-xs); }

    .showcase__overlay {
      padding: var(--space-l) var(--space-m) var(--space-l);
    }

    .showcase::before,
    .showcase::after {
      width: 28px;
    }

    .pipeline__flow {
      flex-direction: column;
      gap: var(--space-s);
    }

    .pipeline__connector {
      width: 24px;
      height: 50px;
      transform: rotate(90deg);
    }

    .example-card {
      flex-direction: column;
    }

    .example-card__arrow {
      padding-block: var(--space-2xs);
    }

    .terminal-strip,
    .pipeline,
    .examples {
      overflow-x: clip;
    }

  }

  @media (max-width: 480px) {
    .showcase {
      --showcase-side-trim: 0px;
    }

    .showcase::before,
    .showcase::after {
      width: 12px;
    }

    .showcase__nav {
      width: 42px;
      height: 42px;
    }

    .showcase__nav svg {
      width: 20px;
      height: 20px;
    }
  }

  /* ── Hero: anclas a los dos bloques ── */
  .auto-hero__tracks {
    display: flex;
    justify-content: center;
    gap: var(--space-xs);
    margin-top: var(--space-m);
    flex-wrap: wrap;
  }

  .auto-hero__track {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--auto-border);
    border-radius: 999px;
    font-size: 0.72rem;
    color: var(--auto-text-secondary);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--ease-out), color var(--duration-fast) var(--ease-out);
  }

  .auto-hero__track span {
    color: var(--auto-accent);
  }

  .auto-hero__track:hover {
    border-color: rgba(57, 211, 83, 0.45);
    color: var(--auto-text);
  }

  /* ── Separadores de bloque (01 After Effects / 02 Empresas) ── */
  .track {
    position: relative;
    z-index: 1;
    background: var(--auto-bg);
    padding-block: var(--space-2xl) var(--space-l);
    scroll-margin-top: 90px;
  }

  .track__inner {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    border-top: 1px solid var(--auto-border);
    padding-top: var(--space-xl);
  }

  .track__num {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(4rem, 3rem + 6vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(57, 211, 83, 0.35);
    flex-shrink: 0;
  }

  .track__kicker {
    display: block;
    color: var(--auto-accent);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-2xs);
  }

  .track__title {
    font-size: var(--step-3);
    color: var(--auto-primary);
    margin-bottom: var(--space-2xs);
  }

  .track__sub {
    color: var(--auto-text-secondary);
    font-size: var(--step-0);
    line-height: 1.6;
    max-width: 62ch;
  }

  .track__sub strong {
    color: var(--auto-accent);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .track__inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-s);
    }
  }

  /* ── Bots para empresas ── */
  .bots__demo {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: var(--space-xl);
    align-items: start;
    margin-bottom: var(--space-2xl);
  }

  /* Chat demo */
  .chat-demo {
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4);
  }

  .chat-demo__bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--auto-border);
    font-size: 0.72rem;
    color: var(--auto-text-secondary);
  }

  .chat-demo__status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--auto-accent);
    box-shadow: 0 0 8px var(--auto-accent);
    animation: chat-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .chat-demo__name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .chat-demo__tag {
    margin-left: auto;
    border: 1px solid rgba(57, 211, 83, 0.35);
    color: var(--auto-accent);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.62rem;
    flex-shrink: 0;
  }

  .chat-demo__messages {
    height: 380px;
    overflow: hidden;
    padding: var(--space-s);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .chat-msg {
    max-width: 84%;
    padding: 0.55rem 0.85rem;
    border-radius: 12px;
    font-size: 0.84rem;
    line-height: 1.45;
    opacity: 0;
    transform: translateY(8px);
    animation: chat-in 0.35s ease forwards;
  }

  .chat-msg--user {
    align-self: flex-end;
    background: rgba(57, 211, 83, 0.13);
    border: 1px solid rgba(57, 211, 83, 0.28);
    color: var(--auto-text);
    border-bottom-right-radius: 4px;
  }

  .chat-msg--bot {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--auto-border);
    color: var(--auto-text);
    border-bottom-left-radius: 4px;
  }

  .chat-msg--sys {
    align-self: center;
    max-width: 100%;
    background: transparent;
    border: none;
    padding: 0.2rem 0;
    color: var(--auto-accent);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.66rem;
    text-align: center;
    opacity: 0;
  }

  .chat-msg--typing {
    display: flex;
    gap: 4px;
    align-items: center;
    min-height: 1.9em;
  }

  .chat-msg--typing i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--auto-text-secondary);
    animation: chat-typing 1s ease-in-out infinite;
  }

  .chat-msg--typing i:nth-child(2) { animation-delay: 0.15s; }
  .chat-msg--typing i:nth-child(3) { animation-delay: 0.3s; }

  .chat-demo__input {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--auto-border);
    color: var(--auto-text-secondary);
    font-size: 0.72rem;
    opacity: 0.65;
  }

  @keyframes chat-in {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes chat-pulse {
    50% { opacity: 0.4; }
  }

  @keyframes chat-typing {
    50% { transform: translateY(-4px); opacity: 0.5; }
  }

  /* Cómo lo monto */
  .bots__how-title {
    color: var(--auto-accent);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-m);
  }

  .bots__flow {
    display: flex;
    align-items: stretch;
    gap: 0.4rem;
    margin-bottom: var(--space-l);
  }

  .bots__flow-node {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    text-align: center;
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-md);
    padding: 0.9rem 0.4rem;
    color: var(--auto-text-secondary);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    line-height: 1.45;
  }

  .bots__flow-node svg {
    color: var(--auto-accent);
  }

  .bots__flow-node--bot {
    border-color: rgba(57, 211, 83, 0.4);
    box-shadow: 0 0 24px rgba(57, 211, 83, 0.08);
    color: var(--auto-text);
  }

  .bots__flow-arrow {
    width: 42px;
    flex-shrink: 0;
    align-self: center;
  }

  .bots__dash {
    animation: bots-dash 1.1s linear infinite;
  }

  @keyframes bots-dash {
    to { stroke-dashoffset: -10; }
  }

  .bots__steps {
    list-style: none;
    counter-reset: bot-step;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    padding: 0;
    margin: 0;
  }

  .bots__steps li {
    counter-increment: bot-step;
    position: relative;
    padding-left: 2.8rem;
    color: var(--auto-text-secondary);
    line-height: 1.55;
    font-size: 0.9rem;
  }

  .bots__steps li::before {
    content: '0' counter(bot-step);
    position: absolute;
    left: 0;
    top: 0.1em;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--auto-accent);
    border: 1px solid rgba(57, 211, 83, 0.3);
    border-radius: 6px;
    padding: 0.12rem 0.4rem;
  }

  .bots__steps strong {
    color: var(--auto-text);
  }

  /* Casos de uso */
  .bots__uses {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }

  .bot-use {
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-lg);
    padding: var(--space-m);
    transition: border-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }

  .bot-use:hover {
    border-color: rgba(57, 211, 83, 0.35);
    transform: translateY(-4px);
  }

  .bot-use__icon {
    color: var(--auto-accent);
    margin-bottom: var(--space-xs);
  }

  .bot-use__title {
    font-size: var(--step-0);
    font-weight: 700;
