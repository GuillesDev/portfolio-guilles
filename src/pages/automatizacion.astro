---
import SectionLayout from '../layouts/SectionLayout.astro';
import { automatizacionVisualisers } from '../data/projects';
---

<SectionLayout
  title="Automatización | Guillermo López"
  description="Detecto procesos repetitivos y los convierto en sistemas automáticos. Plantillas, expresiones y scripts que multiplican la eficiencia."
  theme="automatizacion"
>
  <!-- Number particles background -->
  <canvas class="auto-particles" id="auto-particles" aria-hidden="true"></canvas>

  <!-- Hero título -->
  <section class="auto-hero">
    <div class="auto-hero__content container">
      <h1 class="auto-hero__title">
        <span class="auto-hero__title--full">Automatización</span>
        <span class="auto-hero__title--short">Automatizar</span>
      </h1>
      <p class="auto-hero__sub">Detecto lo repetitivo, lo convierto en sistema y me olvido.</p>
      <div class="auto-hero__tracks" aria-label="Elegir bloque de automatizacion">
        <a class="auto-hero__track" href="#after-effects">
          <span class="auto-hero__track-num mono">01</span>
          <strong>After Effects</strong>
          <small>Grafismo, plantillas y renders que se montan solos</small>
        </a>
        <a class="auto-hero__track" href="#empresas">
          <span class="auto-hero__track-num mono">02</span>
          <strong>Empresas</strong>
          <small>Bots, CRM, citas, documentos y reporting automatizado</small>
        </a>
      </div>
    </div>
  </section>

  <!-- ━━ Bloque 01 · After Effects ━━ -->
  <div class="track" id="after-effects">
    <div class="container track__inner" data-animate="fade-up">
      <span class="track__num" aria-hidden="true">01</span>
      <div class="track__text">
        <span class="track__kicker mono">// after effects</span>
        <h2 class="track__title">Grafismo que se monta solo</h2>
        <p class="track__sub">Plantillas, expresiones y scripts que convierten horas de rotulación en un click.</p>
      </div>
    </div>
  </div>

  <!-- Showcase — lo primero que se ve -->
  <section class="showcase" aria-label="Plantillas automatizadas">
    <div class="showcase__viewport">
      {automatizacionVisualisers.map((item, index) => (
        <article
          class={`showcase__slide ${index === 0 ? 'is-active' : ''}`}
          data-index={index}
        >
          <video
            class="showcase__video"
            preload="metadata"
            playsinline
            muted
            loop
            poster={item.poster}
          >
            <source src={item.video} type="video/mp4" />
          </video>
        </article>
      ))}
    </div>

    <button class="showcase__nav showcase__nav--prev" aria-label="Anterior" data-dir="-1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="showcase__nav showcase__nav--next" aria-label="Siguiente" data-dir="1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <div class="showcase__dots">
      {automatizacionVisualisers.map((_, i) => (
        <button
          class={`showcase__dot ${i === 0 ? 'is-active' : ''}`}
          data-goto={i}
          aria-label={`Ir a plantilla ${i + 1}`}
        >
          <span class="showcase__dot-fill"></span>
        </button>
      ))}
    </div>
  </section>

  <!-- Terminal accent -->
  <section class="terminal-strip">
    <div class="container">
      <div class="terminal-strip__block mono">
        <span><span class="terminal-prompt">~</span> <span class="terminal-cmd">find</span> <span class="terminal-arg">./trabajo</span> <span class="terminal-flag">--repetitivo</span></span>
        <span class="terminal-output">→ 47 procesos manuales</span>
        <span><span class="terminal-prompt">~</span> <span class="terminal-cmd">automatizar</span> <span class="terminal-flag">--todos</span></span>
        <span class="terminal-success">✓ Hecho.</span>
      </div>
    </div>
  </section>

  <!-- ━━ Bloque 02 · Soluciones para empresas ━━ -->
  <div class="track track--business" id="empresas">
    <div class="container track__inner" data-animate="fade-up">
      <span class="track__num" aria-hidden="true">02</span>
      <div class="track__text">
        <span class="track__kicker mono">// soluciones para empresas</span>
        <h2 class="track__title">Automatizaciones que quitan trabajo real</h2>
        <p class="track__sub">
          Chatbots, formularios inteligentes, CRM, agendas, documentos y reportes conectados.
          La idea no es tener mas software: es que las tareas repetidas ocurran solas y queden registradas.
        </p>
      </div>
    </div>
  </div>

  <!-- Bots para empresas -->
  <section class="bots section">
    <div class="container">
      <div class="bots__demo" data-animate="fade-up">
        <!-- Demo: chatbot conversando solo -->
        <div class="chat-demo">
          <div class="chat-demo__bar mono">
            <span class="chat-demo__status" aria-hidden="true"></span>
            <span class="chat-demo__name">Fratelli Pazzi por WhatsApp</span>
            <span class="chat-demo__tag">reserva</span>
          </div>
          <div class="chat-demo__messages" id="chat-messages" aria-label="Conversacion de ejemplo con el chatbot de reservas de Fratelli Pazzi"></div>
          <div class="chat-demo__input mono" aria-hidden="true">
            <span>Mensaje por WhatsApp...</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </div>
        </div>

        <!-- Cómo lo monto: diagrama + pasos -->
        <div class="bots__how">
          <h3 class="bots__how-title mono">// arquitectura de automatizacion</h3>

          <div class="bots__flow" aria-hidden="true">
            <div class="bots__flow-node">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
              <span>Web · WhatsApp<br />· Formularios</span>
            </div>
            <div class="bots__flow-arrow">
              <svg viewBox="0 0 60 24" fill="none"><path class="bots__dash" d="M0 12h44" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/><path d="M40 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2"/></svg>
            </div>
            <div class="bots__flow-node bots__flow-node--bot">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="7" width="14" height="12" rx="3"/><line x1="12" y1="7" x2="12" y2="3"/><circle cx="12" cy="3" r="1" fill="currentColor"/><circle cx="9.5" cy="12.5" r="1" fill="currentColor"/><circle cx="14.5" cy="12.5" r="1" fill="currentColor"/><path d="M9 16h6"/></svg>
              <span>Reglas<br />+ IA + APIs</span>
            </div>
            <div class="bots__flow-arrow">
              <svg viewBox="0 0 60 24" fill="none"><path class="bots__dash" d="M0 12h44" stroke="var(--auto-accent)" stroke-width="2" stroke-dasharray="6 4"/><path d="M40 6l8 6-8 6" stroke="var(--auto-accent)" stroke-width="2"/></svg>
            </div>
            <div class="bots__flow-node">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>CRM · Agenda<br />· Docs · Email</span>
            </div>
          </div>

          <ol class="bots__steps">
            <li><strong>Detecto el cuello de botella.</strong> Donde se pierden mensajes, datos, citas, presupuestos o seguimiento.</li>
            <li><strong>Dibujo el flujo.</strong> Que entra, que decide el sistema, que herramienta toca y que aviso sale.</li>
            <li><strong>Lo conecto.</strong> Web, WhatsApp, email, Sheets, Airtable, Notion, CRM, agenda o APIs propias.</li>
            <li><strong>Lo dejo medible.</strong> Registro de conversaciones, leads, conversiones, errores y tareas completadas.</li>
          </ol>
        </div>
      </div>

    </div>
  </section>

</SectionLayout>

<script is:inline>
  // ── Chat demo: la conversación se escribe sola en bucle ──
  (() => {
    const SCRIPT = [
      { from: 'user', text: 'Hola, ¿podemos reservar mesa para este viernes?' },
      { from: 'bot', text: '¡Claro! Soy el asistente de Fratelli Pazzi. ¿Para cuántas personas sería?' },
      { from: 'user', text: 'Para 4. Si puede ser, sobre las 21:30.' },
      { from: 'bot', text: 'Tengo una mesa libre el viernes a las 21:30 para 4 personas. ¿A qué nombre la dejo?' },
      { from: 'user', text: 'A nombre de Guillermo.' },
      { from: 'bot', text: 'Perfecto, Guillermo. Reserva confirmada para 4 personas este viernes a las 21:30. Te mandamos recordatorio por WhatsApp.' },
      { from: 'sys', text: '→ reserva creada · agenda actualizada · equipo de sala avisado' },
    ];

    function addMsg(box, from, text) {
      const el = document.createElement('div');
      el.className = 'chat-msg chat-msg--' + from;
      const type = from.split(' ')[0];
      if (type === 'user') el.dataset.speaker = 'Cliente';
      if (type === 'bot') el.dataset.speaker = 'Fratelli Pazzi';
      el.textContent = text;
      box.appendChild(el);
      box.scrollTop = box.scrollHeight;
      return el;
    }

    function initChatDemo() {
      const box = document.getElementById('chat-messages');
      if (!box || box.dataset.init) return;
      box.dataset.init = '1';

      // Reduced motion: render the whole conversation statically, no loop
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        SCRIPT.forEach((m) => addMsg(box, m.from, m.text));
        return;
      }

      let i = 0;
      let timer = 0;

      function step() {
        if (!box.isConnected) return; // page swapped away — stop
        if (i >= SCRIPT.length) {
          // Conversation over: pause, clear, restart
          timer = setTimeout(() => {
            box.innerHTML = '';
            i = 0;
            step();
          }, 4200);
          return;
        }
        const msg = SCRIPT[i++];
        if (msg.from === 'bot') {
          const typing = addMsg(box, 'bot chat-msg--typing', '');
          typing.innerHTML = '<i></i><i></i><i></i>';
          timer = setTimeout(() => {
            typing.remove();
            addMsg(box, msg.from, msg.text);
            timer = setTimeout(step, 1400);
          }, 1100);
        } else {
          addMsg(box, msg.from, msg.text);
          timer = setTimeout(step, msg.from === 'sys' ? 1600 : 1000);
        }
      }

      // Start when the demo scrolls into view
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) {
          io.disconnect();
          step();
        }
      }, { threshold: 0.35 });
      io.observe(box);
    }

    initChatDemo();
    document.addEventListener('astro:page-load', initChatDemo);
  })();

  // ── Showcase slider ──
  (() => {
    const slides = document.querySelectorAll('.showcase__slide');
    const dots   = document.querySelectorAll('.showcase__dot');
    const navs   = document.querySelectorAll('.showcase__nav');
    let current  = 0;
    let transitioning = false;

    function goTo(index) {
      if (transitioning || index === current) return;
      transitioning = true;
      const prev = slides[current];
      const next = slides[index];
      const prevVideo = prev.querySelector('video');
      if (prevVideo) { prevVideo.pause(); prevVideo.currentTime = 0; }
      next.classList.add('is-entering');
      requestAnimationFrame(() => {
        next.classList.add('is-active');
        next.classList.remove('is-entering');
        prev.classList.remove('is-active');
        const nextVideo = next.querySelector('video');
        if (nextVideo) nextVideo.play().catch(() => {});
        dots[current].classList.remove('is-active');
        dots[index].classList.add('is-active');
        current = index;
        setTimeout(() => { transitioning = false; }, 600);
      });
    }

    navs.forEach(btn => {
      btn.addEventListener('click', () => {
        const dir = parseInt(btn.dataset.dir);
        goTo((current + dir + slides.length) % slides.length);
      });
    });

    dots.forEach(dot => {
      dot.addEventListener('click', () => goTo(parseInt(dot.dataset.goto)));
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goTo((current + 1) % slides.length);
      if (e.key === 'ArrowLeft')  goTo((current - 1 + slides.length) % slides.length);
    });

    const firstVideo = slides[0]?.querySelector('video');
    if (firstVideo) firstVideo.play().catch(() => {});
  })();

  // ── Number particles ──
  (() => {
    // Respect reduced-motion: skip the continuous particle animation entirely
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const canvas = document.getElementById('auto-particles');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    let w, h, particles = [];
    let mouse = { x: -9999, y: -9999 };
    let raf;

    // Meaningful tokens: automation metrics, binary, code fragments
    const tokens = [
      '0', '1', '0', '1', '0', '1',
      '47', '02', '40', '×10',
      '{}', '()', '=>', '//',
      '0:02', '%', '++', '--',
      'for', 'if', '0x', '&&',
      '47→2', '···', '█', '▓',
    ];

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function createParticle() {
      const size = 10 + Math.random() * 14;
      return {
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: -0.15 - Math.random() * 0.25,
        text: tokens[Math.floor(Math.random() * tokens.length)],
        size: size,
        alpha: 0.04 + Math.random() * 0.08,
        baseAlpha: 0.04 + Math.random() * 0.08,
        phase: Math.random() * Math.PI * 2,
        phaseSpeed: 0.005 + Math.random() * 0.01,
      };
    }

    function init() {
      resize();
      particles = [];
      const count = Math.min(80, Math.floor((w * h) / 18000));
      for (let i = 0; i < count; i++) {
        particles.push(createParticle());
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      const mouseRadius = 120;

      for (const p of particles) {
        p.phase += p.phaseSpeed;
        p.x += p.vx;
        p.y += p.vy;

        // Wrap
        if (p.y < -30) { p.y = h + 30; p.x = Math.random() * w; }
        if (p.x < -30) p.x = w + 30;
        if (p.x > w + 30) p.x = -30;

        // Mouse repulsion
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < mouseRadius) {
          const force = (1 - dist / mouseRadius) * 0.6;
          p.x += (dx / dist) * force * 2;
          p.y += (dy / dist) * force * 2;
        }

        // Pulse
        const pulse = 0.6 + 0.4 * Math.sin(p.phase);
        const alpha = p.baseAlpha * pulse;

        ctx.font = `600 ${p.size}px "JetBrains Mono", monospace`;
        ctx.fillStyle = `rgba(57, 211, 83, ${alpha})`;
        ctx.fillText(p.text, p.x, p.y);
      }

      raf = requestAnimationFrame(draw);
    }

    window.addEventListener('resize', () => { resize(); });
    document.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
    document.addEventListener('mouseleave', () => { mouse.x = -9999; mouse.y = -9999; });

    init();
    draw();

    // Cleanup on page transition
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(raf);
    });
  })();
</script>

<style>
  /* ── Number particles ── */
  .auto-particles {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  /* ── Hero título ── */
  .auto-hero {
    position: relative;
    z-index: 1;
    background: transparent;
    padding-top: calc(var(--space-2xl) + 80px);
    padding-bottom: var(--space-xl);
  }

  .auto-hero__content {
    text-align: center;
  }

  .auto-hero__title {
    font-size: clamp(3rem, 2rem + 5vw, 6rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, #39D353 0%, #39D353 40%, #a8f0b0 65%, #ffffff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-s);
    max-width: 100%;
    white-space: nowrap;
  }

  .auto-hero__title--full {
    display: inline;
  }

  .auto-hero__title--short {
    display: none;
  }

  .auto-hero__sub {
    font-size: var(--step-0);
    color: var(--auto-text-secondary);
    line-height: 1.5;
    max-width: 45ch;
    margin-inline: auto;
  }

  /* ── Terminal strip ── */
  .terminal-strip {
    background: var(--auto-bg);
    padding-block: var(--space-m);
  }

  .terminal-strip__block {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-m);
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.65rem, 0.45rem + 0.6vw, 0.78rem);
    color: var(--auto-text-secondary);
    opacity: 0.6;
  }

  .terminal-prompt {
    color: var(--auto-accent);
  }

  .terminal-cmd {
    color: var(--auto-primary);
    font-weight: 600;
  }

  .terminal-arg {
    color: var(--auto-text-secondary);
  }

  .terminal-flag {
    color: #79C0FF;
  }

  .terminal-output {
    color: var(--auto-text-secondary);
  }

  .terminal-success {
    color: var(--auto-accent);
  }

  /* ── Showcase ── */
  .showcase {
    position: relative;
    width: 100%;
    height: 80vh;
    height: 80dvh;
    --showcase-side-trim: clamp(20px, 5vw, 86px);
    background:
      radial-gradient(ellipse 90% 80% at 50% 50%, rgba(57, 211, 83, 0.08) 0%, transparent 72%),
      linear-gradient(180deg, #0D1117 0%, #121821 100%);
    overflow: hidden;
  }

  .showcase::before,
  .showcase::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: max(7vw, 56px);
    z-index: 2;
    pointer-events: none;
  }

  .showcase::before {
    left: 0;
    background: linear-gradient(to right, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.35) 100%);
  }

  .showcase::after {
    right: 0;
    background: linear-gradient(to left, rgba(13, 17, 23, 0.95) 0%, rgba(13, 17, 23, 0.35) 100%);
  }

  .showcase__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .showcase__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    z-index: 0;
  }

  .showcase__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .showcase__slide.is-entering {
    visibility: visible;
  }

  .showcase__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    clip-path: inset(0 var(--showcase-side-trim));
  }

  .showcase__overlay {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  .showcase__counter {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
  }

  .showcase__title {
    font-size: clamp(1.6rem, 1rem + 2.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .showcase__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-top: var(--space-3xs);
  }

  .showcase__tag {
    font-size: var(--step--2);
    padding: 0.2em 0.6em;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.75);
  }

  .showcase__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 62px;
    height: 62px;
    display: grid;
    place-items: center;
    background: linear-gradient(145deg, rgba(121, 192, 255, 0.22) 0%, rgba(57, 211, 83, 0.24) 100%);
    backdrop-filter: blur(10px) saturate(1.2);
    -webkit-backdrop-filter: blur(10px) saturate(1.2);
    border: 1px solid rgba(57, 211, 83, 0.45);
    border-radius: 50%;
    color: #E6EDF3;
    cursor: pointer;
    box-shadow: 0 0 0 1px rgba(121, 192, 255, 0.2), 0 0 28px rgba(57, 211, 83, 0.28);
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .showcase__nav svg {
    width: 28px;
    height: 28px;
    filter: drop-shadow(0 0 8px rgba(57, 211, 83, 0.45));
  }

  .showcase__nav:hover {
    background: linear-gradient(145deg, rgba(121, 192, 255, 0.34) 0%, rgba(57, 211, 83, 0.38) 100%);
    border-color: rgba(57, 211, 83, 0.78);
    box-shadow: 0 0 0 1px rgba(121, 192, 255, 0.4), 0 0 40px rgba(57, 211, 83, 0.45);
    transform: translateY(-50%) scale(1.1);
  }

  .showcase__nav--prev { left: var(--space-m); }
  .showcase__nav--next { right: var(--space-m); }

  .showcase__dots {
    position: absolute;
