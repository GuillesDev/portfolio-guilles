---
import SectionLayout from '../layouts/SectionLayout.astro';

const features = [
  {
    num: '01',
    title: 'Panel de administración a medida',
    desc: 'Sin WordPress, sin CMS de terceros. Portfolio, alquileres y contenidos se gestionan desde un panel propio con drag & drop entre secciones, edición inline y subida de archivos.',
    tag: 'Producto',
  },
  {
    num: '02',
    title: 'Subida de vídeo por chunks',
    desc: 'Los vídeos pesados se trocean en el navegador y se suben pieza a pieza con barra de progreso real, esquivando los límites del hosting. Hasta 2 GB por archivo, directo al servidor.',
    tag: 'Ingeniería',
  },
  {
    num: '03',
    title: 'Seguridad endurecida',
    desc: 'Sesiones firmadas, rate limiting en el login, validación de archivos por magic bytes, cabeceras HSTS y CSP, protección contra path traversal. Auditoría de seguridad completa aplicada.',
    tag: 'Seguridad',
  },
  {
    num: '04',
    title: 'Rendimiento sin sacrificios',
    desc: 'Páginas estáticas con revalidación instantánea: lo que se guarda en el admin aparece al momento en la web pública. Las imágenes se comprimen en el navegador antes de subir.',
    tag: 'Rendimiento',
  },
  {
    num: '05',
    title: 'Accesibilidad de serie',
    desc: 'Focus traps en modales, navegación por teclado, soporte de prefers-reduced-motion y error boundaries. La web funciona para todos, no solo para quien usa ratón.',
    tag: 'A11y',
  },
  {
    num: '06',
    title: 'Deploy y mantenimiento',
    desc: 'Git push y la web se despliega sola. Deploy keys de solo lectura, secretos fuera del repositorio y base de datos en producción. Mejoras semanales sin romper nada.',
    tag: 'DevOps',
  },
];

const reasons = [
  {
    num: '01',
    title: 'Pienso como diseñador',
    desc: 'Vengo del grafismo. La estética no es una capa final que se añade: cada decisión técnica protege la intención visual.',
  },
  {
    num: '02',
    title: 'Entrego producto, no maquetas',
    desc: 'Black Gum no es un concepto de portfolio: es una plataforma en producción que una empresa real usa cada día para vender.',
  },
  {
    num: '03',
    title: 'Cubro todo el ciclo',
    desc: 'Diseño, frontend, backend, base de datos, seguridad y deploy. Un solo perfil, sin fricción entre piezas.',
  },
  {
    num: '04',
    title: 'Mantengo y mejoro',
    desc: 'Una web viva: auditorías, mejoras de rendimiento y features nuevas cada semana, con builds limpios y sin downtime.',
  },
];
---

<SectionLayout
  title="Desarrollo Web — Guillermo López"
  description="Diseño y desarrollo de productos digitales reales, con criterio visual y enfoque de producto."
  theme="desarrollo"
>
  <!-- Hero -->
  <section class="dev-hero">
    <div class="dev-hero__content container">
      <span class="dev-label mono" data-animate="fade-up">Producto digital · Diseño · Código</span>

      <h1 class="dev-hero__title" data-animate="fade-up">
        Construyo<br />
        <span class="dev-hero__accent">productos digitales</span>
      </h1>

      <p class="dev-hero__subtitle" data-animate="fade-up">
        Vengo del diseño visual y pienso como diseñador, pero entrego
        como desarrollador. Webs, plataformas y sistemas que funcionan
        en producción y resuelven problemas reales.
      </p>

      <span class="dev-hero__tech mono" data-animate="fade-up">
        Next.js · React · TypeScript · Astro · Tailwind · Prisma · Node.js
      </span>
    </div>
  </section>

  <!-- Case study — Black Gum (banda oscura) -->
  <section class="dev-casestudy">
    <div class="casestudy-bg"></div>
    <div class="casestudy-inner container" data-animate="fade-up">

      <div class="casestudy-content">
        <span class="casestudy-kicker mono">Case study</span>

        <img src="/media/blackgum/logo-white.png" alt="Black Gum Studio" class="casestudy-logo" />

        <div class="casestudy-status">
          <span class="casestudy-pulse"></span>
          <span class="casestudy-status__text mono">En producción</span>
        </div>

        <p class="casestudy-desc">
          Plataforma full-stack para una productora audiovisual en Madrid.
          Web pública, panel de administración propio y gestión completa
          de contenidos — todo el stack, del diseño al deploy.
        </p>

        <p class="casestudy-insight">
          "Next.js 14 con App Router y Prisma. Panel admin propio — sin
          WordPress, sin Strapi. Control total."
        </p>

        <span class="casestudy-tech mono">
          Next.js 14 · TypeScript · React · Tailwind · Prisma · Node.js
        </span>

        <div class="casestudy-stats" data-animate="stagger">
          <div class="casestudy-stat">
            <span class="casestudy-stat__value mono">40+</span>
            <span class="casestudy-stat__label">páginas generadas</span>
          </div>
          <div class="casestudy-stat">
            <span class="casestudy-stat__value mono">100%</span>
            <span class="casestudy-stat__label">TypeScript estricto</span>
          </div>
          <div class="casestudy-stat">
            <span class="casestudy-stat__value mono">0</span>
            <span class="casestudy-stat__label">CMS de terceros</span>
          </div>
        </div>

        <a href="https://blackgumgroup.com/" target="_blank" rel="noopener noreferrer" class="casestudy-cta__link mono">
          Ver blackgumgroup.com →
        </a>
      </div>
    </div>
  </section>

  <!-- Qué hay debajo del capó -->
  <section class="dev-features section">
    <div class="container">
      <div class="dev-features__head" data-animate="fade-up">
        <span class="dev-label mono">Debajo del capó</span>
        <h2 class="dev-features__title">
          Lo que hace de Black Gum<br />una web bien construida
        </h2>
        <p class="dev-features__subtitle">
          Una web bonita es la mitad del trabajo. La otra mitad no se ve:
          es lo que hace que sea rápida, segura y fácil de mantener.
        </p>
      </div>

      <div class="dev-features__grid" data-animate="stagger">
        {features.map((f) => (
          <article class="feature-card">
            <div class="feature-card__top">
              <span class="feature-card__num mono">{f.num}</span>
              <span class="feature-card__tag mono">{f.tag}</span>
            </div>
            <h3 class="feature-card__title">{f.title}</h3>
            <p class="feature-card__desc">{f.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué también desarrollador -->
  <section class="dev-why section">
    <div class="container">
      <div class="dev-why__inner">
        <div class="dev-why__head" data-animate="fade-up">
          <span class="dev-label mono">El perfil</span>
          <h2 class="dev-why__title">
            Por qué un grafista<br />puede ser tu desarrollador
          </h2>
        </div>

        <div class="dev-why__list" data-animate="stagger">
          {reasons.map((r) => (
            <div class="why-row">
              <span class="why-row__num mono">{r.num}</span>
              <div class="why-row__body">
                <h3 class="why-row__title">{r.title}</h3>
                <p class="why-row__desc">{r.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="dev-cta section">
    <div class="container">
      <div class="dev-cta__inner" data-animate="fade-up">
        <h2 class="dev-cta__title">¿Tienes un proyecto en mente?</h2>
        <a href="/#contacto" class="dev-cta__link mono">Hablemos →</a>
      </div>
    </div>
  </section>
</SectionLayout>

<style>
  /* ── Hero ── */
  .dev-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--dev-bg);
  }

  .dev-hero__content {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--space-3xl) + 100px);
    padding-bottom: var(--space-3xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dev-label {
    display: inline-block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dev-accent);
    margin-bottom: var(--space-l);
  }

  .dev-hero__title {
    font-size: clamp(3rem, 2rem + 7vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--dev-primary);
    margin-bottom: var(--space-l);
  }

  .dev-hero__accent {
    color: var(--dev-accent);
  }

  .dev-hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--dev-text-secondary);
    max-width: 48ch;
    margin-bottom: var(--space-l);
  }

  .dev-hero__tech {
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    color: var(--dev-text-secondary);
    opacity: 0.5;
  }

  /* ── Case Study — Black Gum (dark band) ── */
  .dev-casestudy {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-3xl);
    background: #0b0b0b;
    color: #f5f0e8;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
  }

  .casestudy-bg {
    position: absolute;
    inset: 0;
    background-image: url('/media/blackgum/hero-bg.png');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.08;
    filter: saturate(0.35) brightness(0.5);
    pointer-events: none;
  }

  .casestudy-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 50% 40%, transparent 30%, rgba(11,11,11,0.88) 100%),
      linear-gradient(to bottom, rgba(11,11,11,0.75) 0%, transparent 25%, transparent 75%, rgba(11,11,11,0.9) 100%);
  }

  .casestudy-kicker {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #d7d1c5;
    opacity: 0.45;
  }

  .casestudy-logo {
    width: clamp(160px, 18vw, 240px);
    height: auto;
    filter: drop-shadow(0 0 30px rgba(199,66,46,0.2));
  }

  .casestudy-inner {
    position: relative;
    z-index: 1;
  }

  .casestudy-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-m);
    max-width: 580px;
    margin-inline: auto;
  }

  .casestudy-status {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.35em 1em;
    border: 1px solid rgba(108,184,126,0.4);
    border-radius: 999px;
  }

  .casestudy-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #6cb87e;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .casestudy-status__text {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #6cb87e;
  }

  .casestudy-desc {
    font-size: var(--step-0);
    line-height: 1.7;
    color: #d7d1c5;
  }

  .casestudy-insight {
    font-size: var(--step--1);
    font-style: italic;
    line-height: 1.6;
    color: #f1a93a;
    padding-left: var(--space-s);
    border-left: 2px solid rgba(241,169,58,0.5);
    text-align: left;
    opacity: 0.85;
    align-self: center;
    max-width: 460px;
  }

  .casestudy-tech {
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    color: #d7d1c5;
    opacity: 0.45;
  }

  .casestudy-stats {
    display: flex;
    gap: var(--space-xl);
    margin-top: var(--space-xs);
  }

  .casestudy-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35em;
  }

  .casestudy-stat__value {
    font-size: var(--step-2);
    font-weight: 700;
    color: #f5f0e8;
    letter-spacing: -0.02em;
  }

  .casestudy-stat__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #d7d1c5;
    opacity: 0.5;
  }

  .casestudy-cta__link {
    display: inline-block;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0b0b0b;
    background: linear-gradient(135deg, #c7422e, #f1a93a);
    padding: 0.75em 2.2em;
    border-radius: var(--radius-sm);
    font-weight: 600;
    transition: all var(--duration-fast) var(--ease-out);
    box-shadow: 0 4px 20px rgba(199,66,46,0.3);
  }

  .casestudy-cta__link:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(199,66,46,0.45);
  }

  /* ── Features grid (debajo del capó) ── */
  .dev-features__head {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: var(--space-2xl);
  }

  .dev-features__title {
    font-size: var(--step-3);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--dev-primary);
    margin-bottom: var(--space-s);
  }

  .dev-features__subtitle {
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--dev-text-secondary);
  }

  .dev-features__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }

  .feature-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-l);
    background: var(--dev-surface);
    border: 1px solid var(--dev-border);
    border-radius: var(--radius-md);
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }

  .feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,0,0,0.07);
  }

  .feature-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-2xs);
  }

  .feature-card__num {
    font-size: var(--step--1);
    color: var(--dev-accent);
    opacity: 0.6;
  }

  .feature-card__tag {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--dev-accent);
    border: 1px solid currentColor;
    border-radius: 999px;
    padding: 0.25em 0.8em;
    opacity: 0.75;
  }

  .feature-card__title {
    font-size: var(--step-0);
    font-weight: 700;
    color: var(--dev-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .feature-card__desc {
    font-size: var(--step--1);
    line-height: 1.65;
    color: var(--dev-text-secondary);
  }

  /* ── Por qué desarrollador ── */
  .dev-why {
    background: var(--dev-surface);
  }

  .dev-why__inner {
    max-width: 760px;
    margin-inline: auto;
  }

  .dev-why__head {
    text-align: center;
    margin-bottom: var(--space-xl);
  }

  .dev-why__title {
    font-size: var(--step-3);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--dev-primary);
  }

  .dev-why__list {
    display: flex;
    flex-direction: column;
  }

  .why-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-l);
    align-items: baseline;
    padding-block: var(--space-m);
    border-bottom: 1px solid var(--dev-border);
  }

  .why-row:last-child {
    border-bottom: none;
  }

  .why-row__num {
    font-size: var(--step-1);
    color: var(--dev-accent);
    opacity: 0.45;
  }

  .why-row__title {
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--dev-primary);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2xs);
  }

  .why-row__desc {
    font-size: var(--step--1);
    line-height: 1.65;
    color: var(--dev-text-secondary);
    max-width: 56ch;
  }

  /* ── CTA ── */
  .dev-cta__inner {
    text-align: center;
    padding-block: var(--space-l);
  }

  .dev-cta__title {
    font-size: var(--step-2);
    color: var(--dev-primary);
    margin-bottom: var(--space-s);
    font-weight: 700;
  }

  .dev-cta__link {
    font-size: var(--step-0);
    color: var(--dev-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .dev-cta__link:hover {
    transform: translateX(6px);
  }

  /* ── Responsive ── */
  @media (max-width: 968px) {
    .dev-features__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .dev-hero__title {
      font-size: clamp(2.2rem, 1.2rem + 5vw, 4rem);
    }

    .casestudy-insight {
      align-self: stretch;
      max-width: 100%;
    }

    .casestudy-stats {
      gap: var(--space-l);
    }

    .dev-features__grid {
      grid-template-columns: 1fr;
    }

    .why-row {
      gap: var(--space-s);
    }
  }
</style>
