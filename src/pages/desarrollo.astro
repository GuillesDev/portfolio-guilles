---
import SectionLayout from '../layouts/SectionLayout.astro';

const stack = [
  { name: 'Next.js', bg: '#111111', fg: '#ffffff' },
  { name: 'React', bg: '#61dafb', fg: '#0f2e36' },
  { name: 'TypeScript', bg: '#3178c6', fg: '#ffffff' },
  { name: 'Astro', bg: '#ff5d01', fg: '#ffffff' },
  { name: 'Tailwind', bg: '#38bdf8', fg: '#082f49' },
  { name: 'Prisma', bg: '#1a202c', fg: '#ffffff' },
  { name: 'Node.js', bg: '#237d23', fg: '#ffffff' },
  { name: 'GSAP', bg: '#88ce02', fg: '#1f2d00' },
];

const features = [
  {
    num: '01',
    title: 'Panel de administración a medida',
    desc: 'Sin WordPress, sin CMS de terceros. Portfolio, alquileres y contenidos se gestionan desde un panel propio con drag & drop entre secciones, edición inline y subida de archivos.',
    tag: 'Producto',
    accent: '#5B7B9A',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>',
  },
  {
    num: '02',
    title: 'Subida de vídeo por chunks',
    desc: 'Los vídeos pesados se trocean en el navegador y se suben pieza a pieza con barra de progreso real, esquivando los límites del hosting. Hasta 2 GB por archivo, directo al servidor.',
    tag: 'Ingeniería',
    accent: '#c7422e',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><path d="M7 9l5-5 5 5M12 4v12"/></svg>',
  },
  {
    num: '03',
    title: 'Seguridad endurecida',
    desc: 'Sesiones firmadas, rate limiting en el login, validación de archivos por magic bytes, cabeceras HSTS y CSP, protección contra path traversal. Auditoría de seguridad completa aplicada.',
    tag: 'Seguridad',
    accent: '#2f9e62',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>',
  },
  {
    num: '04',
    title: 'Rendimiento sin sacrificios',
    desc: 'Páginas estáticas con revalidación instantánea: lo que se guarda en el admin aparece al momento en la web pública. Las imágenes se comprimen en el navegador antes de subir.',
    tag: 'Rendimiento',
    accent: '#f1a93a',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>',
  },
  {
    num: '05',
    title: 'Accesibilidad de serie',
    desc: 'Focus traps en modales, navegación por teclado, soporte de prefers-reduced-motion y error boundaries. La web funciona para todos, no solo para quien usa ratón.',
    tag: 'A11y',
    accent: '#7c6bd6',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="2"/><path d="M4 9h16M12 9v6m0 0l-3 6m3-6l3 6"/></svg>',
  },
  {
    num: '06',
    title: 'Deploy y mantenimiento',
    desc: 'Git push y la web se despliega sola. Deploy keys de solo lectura, secretos fuera del repositorio y base de datos en producción. Mejoras semanales sin romper nada.',
    tag: 'DevOps',
    accent: '#3b82f6',
    icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 00-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 012-3.95A12.88 12.88 0 0122 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 01-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
  },
];

const reasons = [
  {
    num: '01',
    title: 'Pienso como diseñador',
    desc: 'Vengo del grafismo. La estética no es una capa final que se añade: cada decisión técnica protege la intención visual.',
  },
  {
    num: '02',
    title: 'Entrego producto, no maquetas',
    desc: 'Black Gum no es un concepto de portfolio: es una plataforma en producción que una empresa real usa cada día para vender.',
  },
  {
    num: '03',
    title: 'Cubro todo el ciclo',
    desc: 'Diseño, frontend, backend, base de datos, seguridad y deploy. Un solo perfil, sin fricción entre piezas.',
  },
  {
    num: '04',
    title: 'Mantengo y mejoro',
    desc: 'Una web viva: auditorías, mejoras de rendimiento y features nuevas cada semana, con builds limpios y sin downtime.',
  },
