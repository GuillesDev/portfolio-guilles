<script>
  // ── Scramble text reveal (original implementation) ──
  // Letters flicker through random glyphs before settling — terminal style.
  const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<>/{}[]=+*#';

  function scrambleReveal(el: HTMLElement) {
    const original = el.dataset.scrambleText ?? el.textContent ?? '';
    el.dataset.scrambleText = original;
    const len = original.length;
    const duration = 700;
    const start = performance.now();

    function frame(now: number) {
      const t = Math.min((now - start) / duration, 1);
      const settled = Math.floor(t * len);
      let out = original.slice(0, settled);
      for (let i = settled; i < len; i++) {
        out += original[i] === ' ' ? ' ' : GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
      }
      el.textContent = out;
      if (t < 1) requestAnimationFrame(frame);
      else el.textContent = original;
    }
    requestAnimationFrame(frame);
  }

  function initScramble() {
    const els = document.querySelectorAll<HTMLElement>('[data-scramble]');
    if (!els.length) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          scrambleReveal(entry.target as HTMLElement);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.5 });

    els.forEach((el) => io.observe(el));
  }

  // ── Editor typing reveal: lines appear sequentially ──
  function initEditor() {
    const editor = document.getElementById('code-editor');
    const status = document.getElementById('editor-status');
    if (!editor) return;

    const lines = editor.querySelectorAll<HTMLElement>('.editor__line');

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      lines.forEach((l) => l.classList.add('is-visible'));
      if (status) status.innerHTML = '<span class="editor__status-dot editor__status-dot--done" aria-hidden="true"></span>guardado';
      return;
    }

    lines.forEach((l) => l.classList.remove('is-visible'));

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        io.unobserve(entry.target);
        lines.forEach((line, i) => {
          setTimeout(() => {
            line.classList.add('is-visible');
            if (i === lines.length - 1 && status) {
              setTimeout(() => {
                status.innerHTML = '<span class="editor__status-dot editor__status-dot--done" aria-hidden="true"></span>guardado';
              }, 400);
            }
          }, 350 + i * 220);
        });
      });
    }, { threshold: 0.3 });

    io.observe(editor);
  }

  // ── Cursor glow in hero (desktop only) ──
  function initHeroGlow() {
    const glow = document.getElementById('hero-glow');
    if (!glow) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(pointer: coarse)').matches) return;

    const hero = glow.closest('.dev-hero') as HTMLElement | null;
    if (!hero) return;

    let targetX = 0, targetY = 0, x = 0, y = 0;
    let raf = 0;
    let active = false;

    function loop() {
      x += (targetX - x) * 0.08;
      y += (targetY - y) * 0.08;
      glow!.style.transform = `translate(${x - 300}px, ${y - 300}px)`;
      raf = requestAnimationFrame(loop);
    }

    hero.addEventListener('pointermove', (e) => {
      const rect = hero.getBoundingClientRect();
      targetX = e.clientX - rect.left;
      targetY = e.clientY - rect.top;
      if (!active) {
        active = true;
        glow!.style.opacity = '1';
        x = targetX; y = targetY;
        loop();
      }
    });

    hero.addEventListener('pointerleave', () => {
      glow!.style.opacity = '0';
      active = false;
      cancelAnimationFrame(raf);
    });

    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(raf), { once: true });
  }

  // ── 3D wireframe (Three.js, lazy-loaded) ──
  function initHero3D() {
    const mount = document.getElementById('hero-3d');
    if (!mount) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth < 1025) return;

    const probe = document.createElement('canvas');
    if (!(probe.getContext('webgl2') || probe.getContext('webgl'))) return;

    let cleanup: (() => void) | null = null;

    const io = new IntersectionObserver(async (entries) => {
      const visible = entries[0]?.isIntersecting;
      if (visible && !cleanup) {
        io.disconnect();
        cleanup = await buildScene(mount);
      }
    }, { threshold: 0.1 });

    io.observe(mount);

    document.addEventListener('astro:before-swap', () => {
      io.disconnect();
      cleanup?.();
      cleanup = null;
    }, { once: true });
  }

  async function buildScene(mount: HTMLElement): Promise<() => void> {
    const THREE = await import('three');

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(38, 1, 0.1, 30);
    camera.position.z = 5.2;

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    mount.appendChild(renderer.domElement);

    const group = new THREE.Group();
    scene.add(group);

    // Outer icosahedron — blueprint wireframe
    const outerGeo = new THREE.IcosahedronGeometry(1.85, 1);
    const outer = new THREE.LineSegments(
      new THREE.WireframeGeometry(outerGeo),
      new THREE.LineBasicMaterial({ color: 0xf1a93a, transparent: true, opacity: 0.3 })
    );
    group.add(outer);

    // Inner icosahedron — counter-rotating, fainter
    const innerGeo = new THREE.IcosahedronGeometry(1.05, 0);
    const inner = new THREE.LineSegments(
      new THREE.WireframeGeometry(innerGeo),
      new THREE.LineBasicMaterial({ color: 0xc7422e, transparent: true, opacity: 0.22 })
    );
    group.add(inner);

    // Vertex nodes
    const nodes = new THREE.Points(
      outerGeo,
      new THREE.PointsMaterial({ color: 0xf1a93a, size: 0.045, transparent: true, opacity: 0.8 })
    );
    group.add(nodes);

    function resize() {
      const w = mount.clientWidth || 1;
      const h = mount.clientHeight || 1;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    const ro = new ResizeObserver(resize);
    ro.observe(mount);

    // Mouse parallax
    let targetRX = 0, targetRY = 0;
    function onPointer(e: PointerEvent) {
      const nx = (e.clientX / window.innerWidth) * 2 - 1;
      const ny = (e.clientY / window.innerHeight) * 2 - 1;
      targetRY = nx * 0.35;
      targetRX = ny * 0.25;
    }
    window.addEventListener('pointermove', onPointer, { passive: true });

    let raf = 0;
    let running = true;
    const clock = new THREE.Clock();

    function tick() {
      if (!running) return;
      const t = clock.getElapsedTime();
      outer.rotation.y = t * 0.12;
      outer.rotation.x = Math.sin(t * 0.18) * 0.18;
      nodes.rotation.copy(outer.rotation);
      inner.rotation.y = -t * 0.2;
      inner.rotation.z = t * 0.08;
      group.rotation.x += (targetRX - group.rotation.x) * 0.04;
      group.rotation.y += (targetRY - group.rotation.y) * 0.04;
      group.position.y = Math.sin(t * 0.5) * 0.08;
      renderer.render(scene, camera);
      raf = requestAnimationFrame(tick);
    }

    // Pause when hero is off-screen or tab hidden
    const visIO = new IntersectionObserver((entries) => {
      const onScreen = entries[0]?.isIntersecting ?? false;
      if (onScreen && !running) { running = true; tick(); }
      else if (!onScreen) { running = false; cancelAnimationFrame(raf); }
    }, { threshold: 0.05 });
    visIO.observe(mount);

    function onVisibility() {
      if (document.hidden) { running = false; cancelAnimationFrame(raf); }
      else if (!running) { running = true; tick(); }
    }
    document.addEventListener('visibilitychange', onVisibility);

    tick();

    return () => {
      running = false;
      cancelAnimationFrame(raf);
      visIO.disconnect();
      ro.disconnect();
      window.removeEventListener('pointermove', onPointer);
      document.removeEventListener('visibilitychange', onVisibility);
      outerGeo.dispose();
      innerGeo.dispose();
      (outer.material as { dispose(): void }).dispose();
      (inner.material as { dispose(): void }).dispose();
      (nodes.material as { dispose(): void }).dispose();
      renderer.dispose();
      renderer.domElement.remove();
    };
  }

  // ── Robot mascot peeking over the editor ──
  function initEditorBot() {
    const mount = document.getElementById('editor-bot');
    if (!mount) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.innerWidth < 1025) return;

    const probe = document.createElement('canvas');
    if (!(probe.getContext('webgl2') || probe.getContext('webgl'))) return;

    let cleanup: (() => void) | null = null;

    const io = new IntersectionObserver(async (entries) => {
      if (entries[0]?.isIntersecting && !cleanup) {
        io.disconnect();
        cleanup = await buildBot(mount);
      }
    }, { threshold: 0.1 });

    io.observe(mount);

    document.addEventListener('astro:before-swap', () => {
      io.disconnect();
      cleanup?.();
      cleanup = null;
    }, { once: true });
  }

  async function buildBot(mount: HTMLElement): Promise<() => void> {
    const THREE = await import('three');
    const { RoundedBoxGeometry } = await import('three/addons/geometries/RoundedBoxGeometry.js');
    const { buildRobotRig } = await import('../lib/robotRig');

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(35, 1, 0.1, 20);
    camera.position.set(0, 0.62, 3.4);
    camera.lookAt(0, 0.55, 0);

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    mount.appendChild(renderer.domElement);

    // Lights — warm Black Gum mood
    scene.add(new THREE.AmbientLight(0xfff4e0, 1.1));
    const key = new THREE.DirectionalLight(0xffffff, 2.2);
    key.position.set(2, 3, 4);
    scene.add(key);
    const rim = new THREE.PointLight(0xf1a93a, 9, 10);
    rim.position.set(-2, 0.8, 2);
    scene.add(rim);

    const rig = buildRobotRig(THREE, RoundedBoxGeometry);
    const { robot, headGroup, eyeL, eyeR, eyesMat, armRPivot, antennaTip } = rig;
    scene.add(robot);

    function resize() {
      const w = mount.clientWidth || 1;
      const h = mount.clientHeight || 1;
      renderer.setSize(w, h);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    const ro = new ResizeObserver(resize);
    ro.observe(mount);

    // Gaze target from pointer + raycast picking (hit the robot with clicks)
    const raycaster = new THREE.Raycaster();
    const ndc = new THREE.Vector2();
    const editorEl = document.getElementById('code-editor');
    const heroEl = mount.closest('.dev-hero') as HTMLElement | null;

    function pickRobot(clientX: number, clientY: number): boolean {
      const rect = renderer.domElement.getBoundingClientRect();
      ndc.x = ((clientX - rect.left) / rect.width) * 2 - 1;
      ndc.y = -((clientY - rect.top) / rect.height) * 2 + 1;
      if (ndc.x < -1 || ndc.x > 1 || ndc.y < -1 || ndc.y > 1) return false;
      raycaster.setFromCamera(ndc, camera);
      return raycaster.intersectObject(robot, true).length > 0;
    }

    let gazeX = 0, gazeY = 0;
    function onPointer(e: PointerEvent) {
      gazeX = (e.clientX / window.innerWidth) * 2 - 1;
      gazeY = (e.clientY / window.innerHeight) * 2 - 1;
      // Pointer cursor when hovering the visible part of the robot
      if (heroEl) {
        const overEditor = !!editorEl && e.target instanceof Node && editorEl.contains(e.target);
        heroEl.style.cursor = !overEditor && pickRobot(e.clientX, e.clientY) ? 'pointer' : '';
      }
    }
    window.addEventListener('pointermove', onPointer, { passive: true });

    let pendingHit = false;
    function onClick(e: MouseEvent) {
      // Ignore clicks that land on the editor window (robot's hidden lower body)
      if (editorEl && e.target instanceof Node && editorEl.contains(e.target)) return;
      if (pickRobot(e.clientX, e.clientY)) pendingHit = true;
    }
    window.addEventListener('click', onClick);

    let raf = 0;
    let running = true;
    let nextBlink = 2.2;
    let blinkUntil = 0;
    // Damped spring driving the knock-back reaction
    let hitRot = 0;
    let hitVel = 0;
    let lastHit = -10;
    const clock = new THREE.Clock();

    function tick() {
      if (!running) return;
      const dt = Math.min(clock.getDelta(), 0.05);
      const t = clock.elapsedTime;

      // Hit impulse: knock the robot back with a damped spring
      if (pendingHit) {
        pendingHit = false;
        lastHit = t;
        hitVel = -7;
      }
      hitVel += (-90 * hitRot - 8 * hitVel) * dt;
      hitRot += hitVel * dt;
      const hurt = t - lastHit < 0.55;

      // Idle float + sway, plus knock-back lean and shift
      robot.position.y = Math.sin(t * 1.4) * 0.04;
      robot.position.z = hitRot * 0.4;
      robot.rotation.x = hitRot;
      robot.rotation.y = Math.sin(t * 0.55) * 0.06;

      // Gaze follows cursor (clamped, smoothed); head snaps back when hit
      headGroup.rotation.y += (gazeX * 0.5 - headGroup.rotation.y) * 0.07;
      headGroup.rotation.x += (gazeY * 0.3 + hitRot * 0.8 - headGroup.rotation.x) * 0.07;

      // Arms: flail when hurt, greeting wave at start, rest otherwise
      if (hurt) {
        armRPivot.rotation.z += (-2.6 - armRPivot.rotation.z) * 0.3;
      } else if (t < 2.4) {
        armRPivot.rotation.z = -2.3 + Math.sin(t * 9) * 0.28;
      } else {
        armRPivot.rotation.z += (-0.25 - armRPivot.rotation.z) * 0.06;
      }

      // Eyes: pained squint + ember flash while hurt, regular blink otherwise
      if (t > nextBlink) {
        blinkUntil = t + 0.13;
        nextBlink = t + 2.4 + Math.random() * 3;
      }
      const blinking = t < blinkUntil;
      eyesMat.color.setHex(hurt ? 0xc7422e : 0xf1a93a);
      eyeL.scale.y = eyeR.scale.y = hurt ? 0.25 : (blinking ? 0.12 : 1);

      // Antenna pulse — races for a moment after a hit
      const recent = t - lastHit < 1.4;
      antennaTip.scale.setScalar(1 + Math.sin(t * (recent ? 16 : 3)) * (recent ? 0.22 : 0.12));

      renderer.render(scene, camera);
      raf = requestAnimationFrame(tick);
    }

    const visIO = new IntersectionObserver((entries) => {
      const onScreen = entries[0]?.isIntersecting ?? false;
      if (onScreen && !running) { running = true; tick(); }
      else if (!onScreen) { running = false; cancelAnimationFrame(raf); }
    }, { threshold: 0.05 });
    visIO.observe(mount);

    function onVisibility() {
      if (document.hidden) { running = false; cancelAnimationFrame(raf); }
      else if (!running) { running = true; tick(); }
    }
    document.addEventListener('visibilitychange', onVisibility);

    tick();

    return () => {
      running = false;
      cancelAnimationFrame(raf);
      visIO.disconnect();
      ro.disconnect();
      window.removeEventListener('pointermove', onPointer);
      window.removeEventListener('click', onClick);
      document.removeEventListener('visibilitychange', onVisibility);
      if (heroEl) heroEl.style.cursor = '';
      rig.dispose();
      renderer.dispose();
      renderer.domElement.remove();
    };
  }

  // ── Editor 3D tilt following cursor ──
  function initEditorTilt() {
    const wrap = document.getElementById('editor-tilt');
    if (!wrap) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (window.matchMedia('(pointer: coarse)').matches) return;

    const hero = wrap.closest('.dev-hero') as HTMLElement | null;
    if (!hero) return;

    let tx = 0, ty = 0, rx = 0, ry = 0;
    let raf = 0;
    let running = false;

    function loop() {
      rx += (tx - rx) * 0.08;
      ry += (ty - ry) * 0.08;
      wrap!.style.transform = `perspective(1100px) rotateX(${rx}deg) rotateY(${ry}deg)`;
      if (Math.abs(tx - rx) < 0.01 && Math.abs(ty - ry) < 0.01 && tx === 0 && ty === 0) {
        running = false;
        return;
      }
      raf = requestAnimationFrame(loop);
    }

    function start() {
      if (!running) { running = true; loop(); }
    }

    hero.addEventListener('pointermove', (e) => {
      const r = wrap!.getBoundingClientRect();
      const cx = r.left + r.width / 2;
      const cy = r.top + r.height / 2;
      const dx = (e.clientX - cx) / (r.width / 2);
      const dy = (e.clientY - cy) / (r.height / 2);
      const clamp = (v: number) => Math.max(-1.6, Math.min(1.6, v));
      ty = clamp(dx) * 3.2;
      tx = clamp(-dy) * 3.2;
      start();
    }, { passive: true });

    hero.addEventListener('pointerleave', () => {
      tx = 0; ty = 0;
      start();
    });

    document.addEventListener('astro:before-swap', () => cancelAnimationFrame(raf), { once: true });
  }

  document.addEventListener('astro:page-load', () => {
    initScramble();
    initEditor();
    initHeroGlow();
    initHero3D();
    initEditorBot();
    initEditorTilt();
  });
</script>

